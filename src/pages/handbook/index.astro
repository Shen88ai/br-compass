let currentHeroSlide = 0;

function renderHeroSlide(index: number) {
  const slide = heroSlidesData[index];
  const container = document.getElementById('hsl-slide-container');
  const dotsContainer = document.getElementById('hsl-dots');
  if (!container || !dotsContainer) return;

  // Single Source of Truth: 直接從 DOM 讀取 SSR 已計算好的資料
  const cardEl = document.querySelector(`.carousel-slide-card[data-slide-idx="${index}"]`);
  const coverImage = cardEl ? (cardEl as HTMLElement).dataset.cover : null;
  const preview = cardEl ? (cardEl as HTMLElement).dataset.preview : slide.preview;

  container.innerHTML = `
    <div class="hsl-slide">
      <div class="hsl-image-area">
        ${coverImage ? `<img src="${coverImage}" alt="${slide.title}" class="hsl-image" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />` : ''}
        <div class="hsl-image-placeholder" ${coverImage ? 'style="display:none;"' : ''}>
          <span class="hsl-icon">${slide.icon}</span>
        </div>
        <div class="hsl-overlay">
          <span class="hsl-badge">${slide.icon} ${slide.sub}</span>
        </div>
      </div>
      <div class="hsl-info">
        <h2 class="hsl-title">${slide.title}</h2>
        <p class="hsl-preview">${preview}</p>
        <div class="hsl-progress">
          <span>${index + 1} / ${heroSlidesData.length}</span>
        </div>
        <div class="hsl-actions">
          <a href="/handbook/${slide.slug}" class="hsl-btn hsl-btn-primary">完整閱讀 →</a>
          <span class="hsl-hint">或點擊周圍區域關閉</span>
        </div>
      </div>
    </div>
  `;

  dotsContainer.innerHTML = heroSlidesData.map((_, i) => `
    <button class="hsl-dot ${i === index ? 'active' : ''}" data-idx="${i}"></button>
  `).join('');

  dotsContainer.querySelectorAll('.hsl-dot').forEach(dot => {
    dot.addEventListener('click', (e) => {
      const idx = parseInt((e.currentTarget as HTMLElement).dataset.idx || '0');
      currentHeroSlide = idx;
      renderHeroSlide(idx);
    });
  });
}

function openHeroLightbox(startIndex: number) {
  currentHeroSlide = startIndex;
  const lb = document.getElementById('hero-slides-lightbox');
  if (lb) {
    renderHeroSlide(startIndex);
    lb.classList.add('active');
    document.body.style.overflow = 'hidden';
  }
}

function closeHeroLightbox() {
  const lb = document.getElementById('hero-slides-lightbox');
  if (lb) {
    lb.classList.remove('active');
    document.body.style.overflow = '';
  }
}

function navigateHeroSlide(dir: number) {
  currentHeroSlide = (currentHeroSlide + dir + heroSlidesData.length) % heroSlidesData.length;
  renderHeroSlide(currentHeroSlide);
}

(window as any).openHeroLightbox = openHeroLightbox;
(window as any).closeHeroLightbox = closeHeroLightbox;

// Init carousel slide click handlers (with DOMContentLoaded to ensure DOM is ready)
// 防呆機制：重試計數器
let carouselInitRetries = 0;
const MAX_CAROUSEL_INIT_RETRIES = 10;

function initCarouselLightbox() {
  const cards = document.querySelectorAll('.carousel-slide-card');
  
  if (cards.length === 0) {
    carouselInitRetries++;
    if (carouselInitRetries >= MAX_CAROUSEL_INIT_RETRIES) {
      console.warn(`⚠️ Carousel init failed after ${MAX_CAROUSEL_INIT_RETRIES} retries. Elements not found.`);
      return; // 防呆退出
    }
    setTimeout(initCarouselLightbox, 100);
    return;
  }
  
  // 重置計數器
  carouselInitRetries = 0;
  
  cards.forEach(card => {
    card.addEventListener('click', (e) => {
      const idx = parseInt((card as HTMLElement).dataset.slideIdx || '0');
      openHeroLightbox(idx);
    });
    (card as HTMLElement).style.cursor = 'pointer';
  });

  // Nav buttons
  document.getElementById('hsl-prev')?.addEventListener('click', () => navigateHeroSlide(-1));
  document.getElementById('hsl-next')?.addEventListener('click', () => navigateHeroSlide(1));

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    const lb = document.getElementById('hero-slides-lightbox');
    if (!lb?.classList.contains('active')) return;
    if (e.key === 'Escape') closeHeroLightbox();
    if (e.key === 'ArrowLeft') navigateHeroSlide(-1);
    if (e.key === 'ArrowRight') navigateHeroSlide(1);
  });
  
  // Auto-scroll carousel every 5 seconds (only if not hovering)
  let autoScrollInterval: number | undefined;
  
  function stopAutoScroll() {
    if (autoScrollInterval !== undefined) {
      clearInterval(autoScrollInterval);
      autoScrollInterval = undefined;
    }
  }
  
  function startAutoScroll() {
    stopAutoScroll(); // 防呆：確保不會有計時器堆疊
    autoScrollInterval = window.setInterval(() => {
      const carousel = document.getElementById('hero-carousel');
      if (!carousel) return;
      
      const slideWidth = 340;
      const maxScroll = carousel.scrollWidth - carousel.clientWidth;
      
      if (carousel.scrollLeft >= maxScroll - 10) {
        carousel.scrollTo({ left: 0, behavior: 'smooth' });
      } else {
        carousel.scrollBy({ left: slideWidth, behavior: 'smooth' });
      }
    }, 5000);
  }
  
  const carousel = document.getElementById('hero-carousel');
  if (carousel) {
    carousel.addEventListener('mouseenter', stopAutoScroll);
    carousel.addEventListener('mouseleave', startAutoScroll);
    startAutoScroll();
  }
}

// Start initialization
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initCarouselLightbox);
} else {
  initCarouselLightbox();
}


  function handlePathHash() {
    const hash = window.location.hash;
    if (hash.startsWith('#path-')) {
      const path = hash.replace('#path-', '').toUpperCase();
      const checkpoints = pathConfigs[path] || [];
      const pathName = pathNames[path] || `路徑 ${path}`;
      
      const container = document.getElementById('path-checkpoints-container');
      if (container && checkpoints.length > 0) {
        container.innerHTML = `
          <section class="section-pad" style="padding-top: 2rem; padding-bottom: 2rem;">
            <div class="container">
              <h2 class="section-title" style="margin-bottom: 1.5rem;">${pathName} <span style="font-size: 1rem; font-weight: 400; color: var(--color-muted);">${checkpoints.length} 個 checkpoint</span></h2>
              <div class="bento-grid grid-auto-fit">
                ${checkpoints.map((cp, i) => `
                  <a href="/handbook/${cp.slug}" class="bento-card phase-card" style="display: flex; align-items: flex-start; gap: 1rem; text-decoration: none;">
                    <span style="display: inline-flex; align-items: center; justify-content: center; min-width: 2rem; height: 2rem; background: var(--color-gold); color: #000; border-radius: 50%; font-weight: 700; font-size: 0.9rem;">${i + 1}</span>
                    <div style="flex: 1;">
                      <h3 class="phase-card-title" style="font-size: 1rem; margin-bottom: 0.25rem;">${cp.title}</h3>
                      <p class="phase-card-desc" style="font-size: 0.8rem;">⏱️ ${cp.eta}</p>
                    </div>
                  </a>
                `).join('')}
              </div>
            </div>
          </section>
        `;
        container.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }
  }

  window.addEventListener('hashchange', handlePathHash);
  if (window.location.hash) {
    handlePathHash();
  }
</script>


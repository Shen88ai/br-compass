        path: '操作方式：線上申請 e-CPF → 海牙認證委託書 → 宣誓翻譯 → 委任 Procurador → 透過代理人設立公司 → SCE-IED (RDE-IED) 登記'
      }
    }
  };

  const answers: { step: string; answer: string }[] = [];

  function renderStep(step: typeof visaDecisionTree.steps[0]) {
    const stepEl = document.getElementById('dm-step');
    const questionEl = document.getElementById('dm-question');
    const optionsEl = document.getElementById('dm-options');
    const bodyEl = document.getElementById('dm-body');
    const resultEl = document.getElementById('dm-result');

    if (!stepEl || !questionEl || !optionsEl || !bodyEl || !resultEl) return;

    resultEl.style.display = 'none';
    bodyEl.style.display = 'block';

    const stepNum = step.id ? answers.length + 1 : 1;
    stepEl.textContent = `步驟 ${stepNum} / ${visaDecisionTree.steps.length}`;
    questionEl.textContent = step.question;

    optionsEl.innerHTML = '';
    step.options.forEach(opt => {
      const btn = document.createElement('button');
      btn.className = 'decision-map-option';
      btn.innerHTML = `<strong>${opt.label}</strong><br><span style="font-size:0.8rem;color:var(--color-text-muted);">${opt.desc}</span>`;
      btn.addEventListener('click', () => {
        if (opt.next.startsWith('result_')) {
          showResult(opt.next);
        } else {
          answers.push({ step: step.id || 'start', answer: opt.label });
          const nextStep = visaDecisionTree.steps.find(s => s.id === opt.next);
          if (nextStep) renderStep(nextStep);
        }
      });
      optionsEl.appendChild(btn);
    });
  }

  function showResult(resultId: string) {
    const bodyEl = document.getElementById('dm-body');
    const resultEl = document.getElementById('dm-result');
    const badgeEl = document.getElementById('dm-badge');
    const titleEl = document.getElementById('dm-result-title');
    const descEl = document.getElementById('dm-result-desc');
    const pathEl = document.getElementById('dm-result-path');
    const stepEl = document.getElementById('dm-step');

    if (!bodyEl || !resultEl || !badgeEl || !titleEl || !descEl || !pathEl || !stepEl) return;

    const result = visaDecisionTree.results[resultId as keyof typeof visaDecisionTree.results];
    if (!result) return;

    bodyEl.style.display = 'none';
    resultEl.style.display = 'block';
    stepEl.textContent = '推薦結果';
    badgeEl.textContent = result.badge;
    titleEl.textContent = result.title;
    descEl.textContent = result.desc;
    pathEl.innerHTML = `<strong>📋 完整路徑：</strong><br>${result.path}`;
  }

  (window as any).restartVisaDecisionMap = function() {
    answers.length = 0;
    const firstStep = visaDecisionTree.steps[0];
    if (firstStep) renderStep(firstStep);
  };

  const firstStep = visaDecisionTree.steps[0];
  if (firstStep) renderStep(firstStep);
})();

// ── VITEM V Flow ─────────────────────────────────────────────
(function initVitem5Flow() {
  const flowEl = document.getElementById('vitem5-flow');
  if (!flowEl) return;

  const vitem5State: { position: string | null; edu: string | null; exp: string | null; tax: string | null } = { position: null, edu: null, exp: null, tax: null };

  function show(id: string) { const el = document.getElementById(id); if (el) el.style.display = ''; }
  function hide(id: string) { const el = document.getElementById(id); if (el) el.style.display = 'none'; }

  flowEl.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const btn = target.closest('[data-action]');
    if (!btn) return;

    const action = btn.getAttribute('data-action');
    const choice = btn.getAttribute('data-choice');

    if (action === 'vitem5-position') {
      vitem5State.position = choice;
      show('vitem5-arrow-1');
      show('vitem5-edu-step');
    } else if (action === 'vitem5-edu') {
      vitem5State.edu = choice;
      if (choice === 'match') {
        show('vitem5-arrow-3');
        show('vitem5-docs');
      } else {
        show('vitem5-arrow-2');
        show('vitem5-exp-step');
      }
    } else if (action === 'vitem5-exp') {
      vitem5State.exp = choice;
      if (choice === 'yes') {
        show('vitem5-arrow-3');
        show('vitem5-docs');
      } else {
        show('vitem5-arrow-3');
        show('vitem5-fail');
      }
    } else if (action === 'vitem5-review') {
      if (choice === 'pass') {
        show('vitem5-arrow-6');
        show('vitem5-visa');
        setTimeout(() => {
          show('vitem5-arrow-7');
          show('vitem5-tax-step');
        }, 500);
      } else {
        alert('請補充所需文件後重新提交申請。建議諮詢專業移民律師。');
      }
    } else if (action === 'vitem5-tax') {
      vitem5State.tax = choice;
      show('vitem5-arrow-8');
      show('vitem5-tax-result');
      const titleEl = document.getElementById('vitem5-tax-title');
      const descEl = document.getElementById('vitem5-tax-desc');
      if (titleEl && descEl) {
        if (choice === 'yes') {
          titleEl.textContent = '⚠️ 成為巴西稅務居民';
          descEl.textContent = '全球所得需向巴西申報，最高邊際稅率 27.5%。建議諮詢跨國稅務顧問進行稅務規劃。';
          titleEl.style.color = '#FF6B6B';
        } else {
          titleEl.textContent = '維持非稅務居民';
          descEl.textContent = '僅巴西境內所得需申報。但需注意 730 天連續出境會導致居留權自動註銷。';
          titleEl.style.color = 'var(--color-neon-green)';
        }
      }
      setTimeout(() => {
        show('vitem5-arrow-9');
        show('vitem5-pr');
      }, 500);
    } else if (action === 'vitem5-restart') {
      vitem5State.position = null;
      vitem5State.edu = null;
      vitem5State.exp = null;
      vitem5State.tax = null;
      const steps = ['vitem5-arrow-1','vitem5-edu-step','vitem5-arrow-2','vitem5-exp-step','vitem5-arrow-3','vitem5-docs','vitem5-arrow-4','vitem5-fail','vitem5-arrow-5','vitem5-review','vitem5-arrow-6','vitem5-visa','vitem5-arrow-7','vitem5-tax-step','vitem5-arrow-8','vitem5-tax-result','vitem5-arrow-9','vitem5-pr'];
      steps.forEach(id => hide(id));
      const taxTitle = document.getElementById('vitem5-tax-title');
      const taxDesc = document.getElementById('vitem5-tax-desc');
      if (taxTitle) taxTitle.textContent = '';
      if (taxDesc) taxDesc.textContent = '';
    }
  });
})();


---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { glossaryData, chapterTerms, categoryLabels } from '../../data/glossary';
import TaxFunnel from '../../components/TaxVisualization/TaxFunnel.astro';
import TaxRiver from '../../components/TaxVisualization/TaxRiver.astro';
import TaxScale from '../../components/TaxVisualization/TaxScale.astro';
import TaxFactory from '../../components/TaxFactory/TaxFactory.astro';
import TaxRegimeComparator from '../../components/TaxFactory/TaxRegimeComparator.astro';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('handbook');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'handbook'>;
}

const { post } = Astro.props;

if (post.data.redirect_to) {
  return Astro.redirect(post.data.redirect_to, 301);
}

const { Content, headings } = await render(post);

// Get cover image from frontmatter
const images = post.data.images || {};
const coverFilename = images.cover;
const coverImagePath = coverFilename 
  ? `/images/handbook/${post.id}/${coverFilename}` 
  : null;

const allPosts = (await getCollection('handbook')).sort((a, b) => a.data.order - b.data.order);
const idx = allPosts.findIndex(p => p.id === post.id);
const prev = idx > 0 ? allPosts[idx - 1] : null;
const next = idx < allPosts.length - 1 ? allPosts[idx + 1] : null;

const phaseColors: Record<string, string> = {
  preparation: 'var(--color-platinum)',
  foundation:  'var(--color-gold)',
  operations:  'var(--color-neon-yellow)',
  harvest:     'var(--color-neon-green)',
};
const phaseColor = phaseColors[post.data.phase] || 'var(--color-gold)';
const phaseRgb: Record<string, string> = {
  preparation: '232,228,217',
  foundation:  '212,168,67',
  operations:  '229,255,0',
  harvest:     '0,255,135',
};
const rgb = phaseRgb[post.data.phase] || '212,168,67';

// Get chapter-specific terms
const chapterTermKeys = chapterTerms[post.id] || [];
const chapterGlossaryEntries = glossaryData.filter(g => chapterTermKeys.includes(g.term));

// Build glossary map for tooltip
const glossaryMap: Record<string, typeof glossaryData[0]> = {};
glossaryData.forEach(g => { glossaryMap[g.term] = g; });

// Show Tax visualization components
const showTaxRegimeComparator = post.id.includes('04b-tax-comparison-modes');
const showTaxFunnel = post.id.includes('04b-tax-comparison-modes');
const showTaxScale = post.id.includes('04b-tax-comparison-modes');
const showTaxRiver = post.id.includes('04a-tax-comparison-intro');
const showTaxFactory = false;
---

<Layout title={post.data.title} description={post.data.description}>
  <!-- Reading Progress Bar -->
  <div class="reading-progress">
    <div class="reading-progress-bar" id="progress-bar"></div>
  </div>

  <div class="article-layout">

    <!-- ── Article Main ─────────────────────────────── -->
    <article class="article-main">
      <!-- Breadcrumb -->
      <nav class="breadcrumb">
        <a href="/">首頁</a>
        <span class="breadcrumb-sep">›</span>
        <a href="/handbook">出海實戰手冊</a>
        <span class="breadcrumb-sep">›</span>
        <span style={`color:${phaseColor};`}>{post.data.phaseLabel}</span>
      </nav>

      <!-- Phase badge -->
      <div class="phase-badge" style={`background:rgba(${rgb},0.1);border:1px solid ${phaseColor}40;color:${phaseColor};`}>
        {post.data.icon} {post.data.phaseLabel}
      </div>

      <!-- Title -->
      <h1 class="article-title-main text-gradient-hope">{post.data.title}</h1>
      <p class="article-subtitle">{post.data.description}</p>

      <!-- Cover Image -->
      {coverImagePath ? (
        <div class="article-cover">
          <img 
            src={coverImagePath} 
            alt={post.data.title}
          />
        </div>
      ) : (
        <div class="img-placeholder article-cover" title="[圖片佔位] 請上傳封面圖">
          <span class="cover-icon">{post.data.icon}</span>
          <span class="cover-hint">封面圖片 · 點擊上傳</span>
        </div>
      )}

      <!-- Tags -->
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="article-tags">
          {post.data.tags.map(tag => (
            <span class="tag-item"># {tag}</span>
          ))}
        </div>
      )}

      <!-- ★ Chapter Vocabulary Preview (Phase 3) ────────────────── -->
      {chapterGlossaryEntries.length > 0 && (
        <div class="chapter-vocab-preview" id="chapter-vocab">
          <div class="vocab-header">
            <span class="vocab-icon">📖</span>
            <div class="vocab-title-group">
              <h3 class="vocab-title">本章必學詞彙</h3>
              <span class="vocab-count">{chapterGlossaryEntries.length} 個專有名詞</span>
            </div>
            <button class="vocab-toggle-btn" onclick="toggleVocabPreview()">
              <span class="vocab-toggle-text">展開詳細說明</span>
              <span class="vocab-toggle-icon">▼</span>
            </button>
          </div>
          <div class="vocab-content" id="vocab-content" style="display:none;">
            {chapterGlossaryEntries.map((entry) => {
              const cat = categoryLabels[entry.category];
              return (
                <div class="vocab-card" data-term={entry.term}>
                  <div class="vocab-card-header">
                    <div class="vocab-card-term">
                      <span class="vocab-card-term-text">{entry.term}</span>
                      <span class="vocab-card-pronunciation" title="發音">{entry.pronunciation}</span>
                    </div>
                    <span class="vocab-card-category" style={`background:${cat.color}20;color:${cat.color};`}>
                      {cat.icon} {cat.label}
                    </span>
                  </div>
                  <div class="vocab-card-body">
                    <div class="vocab-card-analogy">{entry.analogy}</div>
                    <div class="vocab-card-oneliner">{entry.oneLiner}</div>
                    <div class="vocab-card-fullname" title="葡語全名">{entry.fullPortuguese}</div>
                  </div>
                  <div class="vocab-card-details" id={`vocab-detail-${entry.term}`} style="display:none;">
                    <div class="vocab-detail-section">
                      <h4 class="vocab-detail-title">📖 詳細說明</h4>
                      <p class="vocab-detail-text">{entry.fullExplanation}</p>
                    </div>
                    <div class="vocab-detail-section">
                      <h4 class="vocab-detail-title">💡 實戰提醒</h4>
                      <ul class="vocab-detail-list">
                        {entry.practicalTips.map(tip => (
                          <li>{tip}</li>
                        ))}
                      </ul>
                    </div>
                    <div class="vocab-detail-section">
                      <h4 class="vocab-detail-title">⚠️ 常見錯誤</h4>
                      <ul class="vocab-detail-list vocab-error-list">
                        {entry.commonMistakes.map(mistake => (
                          <li>{mistake}</li>
                        ))}
                      </ul>
                    </div>
                  </div>
                  <button class="vocab-expand-btn" onclick={`toggleVocabDetail('${entry.term}')`}>
                    展開詳細說明
                  </button>
                </div>
              );
            })}
          </div>
          <div class="vocab-footer">
            <a href="/handbook/glossary" class="vocab-glossary-link">
              📚 前往完整巴西詞典 →
            </a>
          </div>
        </div>
      )}

      <!-- Markdown Content -->
      <div class="prose-custom">
        <Content />
      </div>

      {showTaxScale && <TaxScale />}
      {showTaxFactory && <TaxFactory />}
      {showTaxRegimeComparator && <TaxRegimeComparator />}
      {showTaxFunnel && <TaxFunnel />}
      {showTaxRiver && <TaxRiver />}

      <!-- ── Persona Journey MiniMap ─────────────────── -->
      <div class="journey-minimap persona-hidden" id="journey-minimap">
        <div class="minimap-info">
          <span class="minimap-path-name" id="minimap-path-name"></span>
          <span class="minimap-progress" id="minimap-progress"></span>
          <span class="minimap-current-title" id="minimap-current-title"></span>
        </div>
        <div class="minimap-track" id="minimap-track"></div>
      </div>

      <!-- ── Persona Journey Side Panel (右下角固定) ── -->
      <div class="journey-side-panel persona-hidden" id="journey-side-panel">
        <div class="side-panel-toggle" id="side-panel-toggle">🧭</div>
        <div class="side-panel-content" id="side-panel-content">
          <div class="side-panel-header">
            <h4 class="side-panel-title" id="side-panel-title"></h4>
            <span class="side-panel-progress" id="side-panel-progress"></span>
          </div>
          <div class="side-panel-track" id="side-panel-track"></div>
          <a href="/" class="side-panel-home-btn">🏠 返回首頁重選角色</a>
        </div>
      </div>

      <!-- ── Prev / Next ─────────────────────────────── -->
      <div class="article-nav">
        {prev ? (
          <a href={`/handbook/${prev.id}`} class="card nav-prev">
            <div class="nav-prev-label">← 上一章</div>
            <div class="nav-prev-title">{prev.data.icon} {prev.data.title}</div>
          </a>
        ) : <div />}
        {next ? (
          <a href={`/handbook/${next.id}`} class="card nav-next" style="text-align:right;">
            <div class="nav-next-label">下一章 →</div>
            <div class="nav-next-title">{next.data.icon} {next.data.title}</div>
          </a>
        ) : <div />}
      </div>

      <!-- ── Persona Journey Nav ─────────────────────── -->
      <div class="journey-navigation persona-hidden" id="journey-navigation">
        <div class="nav-celebration" id="celebration">
          <div class="celebration-badge">
            <span class="badge-icon">✅</span>
            <span class="badge-text" id="nav-celebration-text"></span>
          </div>
          <div class="celebration-stamp">
            <span class="stamp-icon">🏅</span>
            <span class="stamp-text" id="nav-stamp-text"></span>
          </div>
        </div>
        <div class="nav-chapters" id="nav-chapters"></div>
        <div id="nav-cta-container"></div>
        <div class="nav-actions">
          <a href="/handbook" class="nav-action">
            <span>🗺️</span>
            <span>查看完整地圖</span>
          </a>
        </div>
      </div>
    </article>

    <!-- ── Sidebar TOC ───────────────────────────────── -->
    <aside class="article-sidebar">
      <div class="card toc-card">
        <div class="toc-title">📑 本章目錄</div>
        {headings.length > 0 ? (
          <nav>
            {(() => {
              const tocColors = [
                'var(--color-platinum)',
                'var(--color-gold)',
                'var(--color-neon-yellow)',
                'var(--color-neon-green)',
                'var(--color-sky-blue)',
              ];
              let colorIdx = 0;
              return headings.map((h) => {
                const hasNumber = /[一二三四五六七八九十]/.test(h.text);
                const tocColor = hasNumber ? tocColors[colorIdx++ % tocColors.length] : 'var(--color-text-muted)';
                return (
                  <a
                    href={`#${h.slug}`}
                    class="toc-link"
                    style={`padding-left:${(h.depth - 2) * 0.75}rem;margin-left:${(h.depth - 2) * 0.75}rem;color:${tocColor};`}
                  >
                    {h.text}
                  </a>
                );
              });
            })()}
          </nav>
        ) : (
          <p style="font-size:0.8rem;color:var(--color-muted);">無章節標題</p>
        )}

        <!-- Back to timeline -->
        <div class="toc-back">
          <a href="/handbook" class="toc-back-link">
            ← 返回時間軸
          </a>
        </div>
      </div>

      <!-- CTA sidebar -->
      <div class="card sidebar-cta">
        <div class="cta-icon">💬</div>
        <div class="cta-title">需要專業協助？</div>
        <p class="cta-desc">我們的巴西稅務專家可為您提供一對一解答。</p>
        <a href="https://braziltax.netlify.app/#contact" class="btn-gold-outline cta-btn-sm">免費預約諮詢</a>
      </div>
    </aside>
  </div>
</Layout>

<!-- Inject glossary data for client-side scripts -->
<script define:vars={{ glossaryMap }}>
  window.__GLOSSARY_MAP__ = glossaryMap;
</script>

<style is:global>
.prose-custom {
  color: var(--color-text);
  line-height: 1.8;
  font-size: 1rem;
}
.prose-custom h2 {
  font-size: 1.5rem;
  border-bottom: 1px solid var(--color-border);
  padding-bottom: 0.5rem;
  margin: 2.5rem 0 1rem;
}
.prose-custom h3 {
  font-size: 1.15rem;
  color: var(--color-text);
  margin: 2rem 0 0.75rem;
}
.prose-custom h4 {
  font-size: 1rem;
  color: var(--color-gold-light);
  margin: 1.5rem 0 0.5rem;
}
.prose-custom p { margin: 0 0 1rem; }
.prose-custom ul, .prose-custom ol {
  padding-left: 1.5rem;
  margin: 0 0 1rem;
}
.prose-custom li { margin-bottom: 0.4rem; }
.prose-custom strong { color: var(--color-gold); }
.prose-custom em { color: var(--color-muted); }
.prose-custom code {
  background: rgba(var(--color-gold-rgb),0.1);
  border: 1px solid rgba(var(--color-gold-rgb),0.2);
  border-radius: 0.25rem;
  padding: 0.1em 0.4em;
  font-size: 0.85em;
  color: var(--color-gold);
}
.prose-custom pre {
  background: var(--color-bg-800);
  border: 1px solid var(--color-border);
  border-radius: 0.75rem;
  padding: 1.25rem;
  overflow-x: auto;
  margin: 1.5rem 0;
}
.prose-custom blockquote {
  border-left: 3px solid var(--color-gold);
  background: rgba(var(--color-gold-rgb),0.05);
  padding: 0.75rem 1rem;
  border-radius: 0 0.5rem 0.5rem 0;
  margin: 1.5rem 0;
  color: var(--color-muted);
}
.prose-custom table {
  width: 100%;
  border-collapse: collapse;
  margin: 1.5rem 0;
  font-size: 0.9rem;
}
.prose-custom th {
  background: rgba(var(--color-gold-rgb),0.1);
  color: var(--color-gold);
  padding: 0.6rem 1rem;
  border: 1px solid var(--color-border);
  text-align: left;
}
.prose-custom td {
  padding: 0.6rem 1rem;
  border: 1px solid var(--color-border);
  color: var(--color-muted);
}
.prose-custom tr:hover td { background: rgba(var(--color-gold-rgb),0.03); }

.callout-decision, .callout-warning, .callout-tip { margin: 1.5rem 0; }
</style>

<script>
// Color the numbered headings in article content
(function initHeadingColors() {
  const prose = document.querySelector('.prose-custom');
  if (!prose) return;
  
  const headingColors = [
    'var(--color-platinum)',
    'var(--color-gold)',
    'var(--color-neon-yellow)',
    'var(--color-neon-green)',
    'var(--color-sky-blue)',
  ];
  let colorIdx = 0;
  
  const h2s = prose.querySelectorAll('h2');
  h2s.forEach((h2) => {
    const hasNumber = /[一二三四五六七八九十]/.test(h2.textContent || '');
    if (hasNumber) {
      h2.style.color = headingColors[colorIdx++ % headingColors.length];
    }
  });
})();
</script>

<script>
// ── Reading Progress Bar ──────────────────────────────────
(function initProgressBar() {
  const bar = document.getElementById('progress-bar');
  if (!bar) return;

  const onScroll = () => {
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
    bar.style.width = `${Math.min(progress, 100)}%`;
  };

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
})();

// ── Tax Regime Quiz ────────────────────────────────────────
(function initTaxQuiz() {
  const quizEl = document.querySelector('[data-quiz="tax-regime"]');
  if (!quizEl) return;

  const questions = [
    {
      q: '你的公司預計年營收規模是多少？',
      options: [
        { text: '低於 R$4,800 萬（Simples Nacional 資格）', score: 0 },
        { text: 'R$4,800 萬 ~ R$7,800 萬（Lucro Presumido 資格）', score: 1 },
        { text: '超過 R$7,800 萬（必須 Lucro Real）', score: 2 },
      ]
    },
    {
      q: '你的進口貨物是否需要大量稅金抵扣？',
      options: [
        { text: '是，進口金額佔營收 30% 以上', score: 2 },
        { text: '部分需要，進口金額 10%~30%', score: 1 },
        { text: '幾乎不需要進口', score: 0 },
      ]
    },
    {
      q: '你的企業預計在初期（1~2 年）是否會有虧損？',
      options: [
        { text: '是，預計先期虧損較大', score: 2 },
        { text: '不確定', score: 1 },
        { text: '否，預計立即盈利', score: 0 },
      ]
    },
    {
      q: '你的會計團隊是否具備 Lucro Real 記帳能力？',
      options: [
        { text: '是，已有專業會計師', score: 0 },
        { text: '需要尋找', score: 1 },
        { text: '否，希望簡化記帳', score: -1 },
      ]
    },
    {
      q: '你是否計劃在未來 3 年內引入外部投資？',
      options: [
        { text: '是，需要財務透明度', score: 2 },
        { text: '可能', score: 1 },
        { text: '否，自營為主', score: 0 },
      ]
    },
  ];

  const results = {
    real: {
      title: '🎯 推薦方案：Lucro Real（實際利潤制）',
      desc: '根據你的回答，Lucro Real 是最適合你的稅制。它能讓你抵扣進口稅金、結轉虧損，並提供更高的財務透明度——非常適合跨境電商。建議立即與會計師確認開戶與首次申報時間。',
    },
    presumido: {
      title: '🎯 推薦方案：Lucro Presumido（推定利潤制）',
      desc: '根據你的回答，Lucro Presumido 可能適合你。它記帳簡單、合規成本低。但請注意：進口稅金無法抵扣，如果你的進口量增加，建議重新評估是否切換至 Lucro Real。',
    },
    unclear: {
      title: '📋 建議：預約專業稅務諮詢',
      desc: '根據你的回答，目前難以給出明確建議。建議預約我們的巴西稅務專家進行一對一評估，綜合考量你的營收預測、進口規模和長期規劃。',
    },
  };

  let currentQ = 0;
  let totalScore = 0;

  const questionEl = quizEl.querySelector('#quiz-question')!;
  const optionsEl = quizEl.querySelector('#quiz-options')!;
  const progressEl = quizEl.querySelector('#quiz-progress')!;
  const resultEl = quizEl.querySelector('#quiz-result')!;
  const resultTitle = quizEl.querySelector('#result-title')!;
  const resultDesc = quizEl.querySelector('#result-desc')!;
  const quizBody = quizEl.querySelector('#quiz-body')!;

  function renderQuestion() {
    const q = questions[currentQ];
    questionEl.textContent = q.q;
    progressEl.textContent = `問題 ${currentQ + 1} / ${questions.length}`;
    optionsEl.innerHTML = '';
    q.options.forEach(opt => {
      const btn = document.createElement('button');
      btn.className = 'quiz-option';
      btn.textContent = opt.text;
      btn.addEventListener('click', () => handleAnswer(opt.score));
      optionsEl.appendChild(btn);
    });
  }

  function handleAnswer(score: number) {
    totalScore += score;
    currentQ++;
    if (currentQ < questions.length) {
      renderQuestion();
    } else {
      showResult();
    }
  }

  function showResult() {
    quizBody.style.display = 'none';
    resultEl.style.display = 'block';
    progressEl.textContent = '測驗完成';

    let result;
    if (totalScore >= 5) result = results.real;
    else if (totalScore >= 2) result = results.presumido;
    else result = results.unclear;

    resultTitle.textContent = result.title;
    resultDesc.textContent = result.desc;
  }

  (window as any).restartQuiz = function() {
    currentQ = 0;
    totalScore = 0;
    quizBody.style.display = 'block';
    resultEl.style.display = 'none';
    renderQuestion();
  };

  renderQuestion();
})();

// ── Tax Compare Calculator ─────────────────────────────────
(function initTaxCompare() {
  const container = document.getElementById('tax-compare');
  if (!container) return;

  const parseBR = (val: string) => {
    const cleaned = val.replace(/\./g, '').replace(/,/g, '.');
    return parseFloat(cleaned) || 0;
  };

  const formatBR = (n: number) =>
    n.toLocaleString('pt-BR', { minimumFractionDigits: 0, maximumFractionDigits: 2 });

  const filterInput = (val: string) => val.replace(/[^0-9.,]/g, '');

  const fmt = (n: number) => 'R$ ' + n.toLocaleString('pt-BR', { minimumFractionDigits: 0, maximumFractionDigits: 0 });

  const el = (id: string) => document.getElementById(id);

  function calcReal() {
    const revenue = parseBR((el('real-revenue') as HTMLInputElement).value);
    const cost = parseBR((el('real-cost') as HTMLInputElement).value);
    const importTax = parseBR((el('real-import-tax') as HTMLInputElement).value);
    const profit = Math.max(revenue - cost, 0);
    const irpjBase = profit * 0.15;
    const irpjAdd = profit > 240000 ? (profit - 240000) * 0.1 : 0;
    const csll = profit * 0.09;
    const total = irpjBase + irpjAdd + csll - importTax;
    const isRefund = total < 0;

    (el('real-profit') as HTMLElement).textContent = fmt(profit);
    (el('real-irpj') as HTMLElement).textContent = fmt(irpjBase);
    (el('real-irpj-add') as HTMLElement).textContent = fmt(irpjAdd);
    (el('real-csll') as HTMLElement).textContent = fmt(csll);
    (el('real-credit') as HTMLElement).textContent = '-' + fmt(importTax);
    const totalEl = el('real-total') as HTMLElement;
    totalEl.textContent = (isRefund ? '退稅 ' : '') + fmt(Math.abs(total));
    totalEl.style.color = isRefund ? '#34d399' : '';
  }

  function calcPresumido() {
    const revenue = parseBR((el('pres-revenue') as HTMLInputElement).value);
    const type = (el('pres-type') as HTMLSelectElement).value;
    const rate = type === 'commerce' ? 0.08 : 0.32;
    const base = revenue * rate;
    const irpj = base * 0.15;
    const irpjAdd = base > 240000 ? (base - 240000) * 0.1 : 0;
    const csll = base * 0.09;
    const total = irpj + irpjAdd + csll;

    (el('pres-base') as HTMLElement).textContent = fmt(base);
    (el('pres-irpj') as HTMLElement).textContent = fmt(irpj);
    (el('pres-irpj-add') as HTMLElement).textContent = fmt(irpjAdd);
    (el('pres-csll') as HTMLElement).textContent = fmt(csll);
    (el('pres-total') as HTMLElement).textContent = fmt(total);
  }

  function update() {
    calcReal();
    calcPresumido();
  }

  // ── Revenue sync (FIXED: both sides recalculate on every change) ──
  const realRevEl = el('real-revenue') as HTMLInputElement;
  const presRevEl = el('pres-revenue') as HTMLInputElement;
  let syncing = false;

  realRevEl.addEventListener('input', () => {
    if (syncing) return;
    syncing = true;
    presRevEl.value = realRevEl.value;
    syncing = false;
    update();
  });

  presRevEl.addEventListener('input', () => {
    if (syncing) return;
    syncing = true;
    realRevEl.value = presRevEl.value;
    syncing = false;
    update();
  });

  // ── Other inputs trigger full recalc ──
  container.querySelectorAll('input:not(#real-revenue):not(#pres-revenue), select').forEach(inputEl => {
    inputEl.addEventListener('input', update);
    inputEl.addEventListener('change', update);
  });

  // ── Input filtering: strip non-numeric chars on every keystroke ──
  container.querySelectorAll('input[type="text"][inputmode="numeric"]').forEach(inputEl => {
    inputEl.addEventListener('input', (e) => {
      const target = e.target as HTMLInputElement;
      target.value = filterInput(target.value);
    });
  });

  // ── Auto-format on blur, restore plain number on focus ──
  container.querySelectorAll('input[type="text"][inputmode="numeric"]').forEach(inputEl => {
    inputEl.addEventListener('blur', () => {
      const num = parseBR(inputEl.value);
      if (num > 0) inputEl.value = formatBR(num);
    });
    inputEl.addEventListener('focus', () => {
      const num = parseBR(inputEl.value);
      if (num > 0) inputEl.value = String(Math.round(num));
    });
  });

  update();
})();

// ── Glossary Tooltip (Phase 4: Knowledge Card) ─────────────
(function initGlossaryTooltip() {
  const glossaryMap = (window as any).__GLOSSARY_MAP__ || {};

  const tooltip = document.createElement('div');
  tooltip.className = 'term-tooltip term-tooltip-expanded';
  tooltip.innerHTML = `
    <div class="tooltip-header">
      <h5 class="term-tooltip-title"></h5>
      <span class="tooltip-pronunciation"></span>
    </div>
    <div class="tooltip-body">
      <div class="tooltip-analogy"></div>
      <div class="tooltip-oneliner"></div>
      <div class="tooltip-fullname"></div>
      <div class="tooltip-fulltext"></div>
      <div class="tooltip-tips" style="display:none;">
        <h6>💡 實戰提醒</h6>
        <ul></ul>
      </div>
      <div class="tooltip-mistakes" style="display:none;">
        <h6>⚠️ 常見錯誤</h6>
        <ul></ul>
      </div>
    </div>
    <div class="tooltip-footer">
      <button class="tooltip-expand-more" onclick="toggleTooltipMore()">展開詳細說明</button>
      <a href="/handbook/glossary" class="tooltip-glossary-link">📚 完整詞典</a>
    </div>
  `;
  document.body.appendChild(tooltip);

  function showTooltip(term: string, x: number, y: number) {
    const data = glossaryMap[term];
    if (!data) return;

    tooltip.querySelector('.term-tooltip-title')!.textContent = `${data.term} — ${data.chineseName}`;
    tooltip.querySelector('.tooltip-pronunciation')!.textContent = `🔊 ${data.pronunciation}`;
    tooltip.querySelector('.tooltip-analogy')!.textContent = data.analogy;
    tooltip.querySelector('.tooltip-oneliner')!.textContent = data.oneLiner;
    tooltip.querySelector('.tooltip-fullname')!.textContent = data.fullPortuguese;
    tooltip.querySelector('.tooltip-fulltext')!.textContent = data.fullExplanation;

    // Tips
    const tipsEl = tooltip.querySelector('.tooltip-tips')!;
    const tipsUl = tipsEl.querySelector('ul')!;
    tipsUl.innerHTML = '';
    if (data.practicalTips.length > 0) {
      tipsEl.style.display = 'block';
      data.practicalTips.forEach(t => {
        const li = document.createElement('li');
        li.textContent = t;
        tipsUl.appendChild(li);
      });
    } else {
      tipsEl.style.display = 'none';
    }

    // Mistakes
    const mistakesEl = tooltip.querySelector('.tooltip-mistakes')!;
    const mistakesUl = mistakesEl.querySelector('ul')!;
    mistakesUl.innerHTML = '';
    if (data.commonMistakes.length > 0) {
      mistakesEl.style.display = 'block';
      data.commonMistakes.forEach(m => {
        const li = document.createElement('li');
        li.textContent = m;
        mistakesUl.appendChild(li);
      });
    } else {
      mistakesEl.style.display = 'none';
    }

    // Reset expand state
    tooltip.classList.remove('tooltip-show-more');

    // Position
    const tooltipRect = tooltip.getBoundingClientRect();
    const vw = window.innerWidth;
    const vh = window.innerHeight;
    let left = x + 16;
    let top = y + 16;
    if (left + 400 > vw) left = x - 400;
    if (top + 500 > vh) top = y - 500;
    if (left < 8) left = 8;
    if (top < 8) top = 8;
    tooltip.style.left = `${left}px`;
    tooltip.style.top = `${top}px`;
    tooltip.classList.add('visible');
  }

  function hideTooltip() {
    tooltip.classList.remove('visible');
  }

  (window as any).toggleTooltipMore = function() {
    tooltip.classList.toggle('tooltip-show-more');
    const btn = tooltip.querySelector('.tooltip-expand-more') as HTMLElement;
    if (btn) {
      btn.textContent = tooltip.classList.contains('tooltip-show-more') ? '收起詳細說明' : '展開詳細說明';
    }
  };

  // Auto-link terms in article content
  const articleContent = document.querySelector('.prose-custom');
  if (articleContent) {
    const walker = document.createTreeWalker(articleContent, NodeFilter.SHOW_TEXT, null);
    const textNodes: Text[] = [];
    while (walker.nextNode()) textNodes.push(walker.currentNode as Text);

    const sortedTerms = Object.keys(glossaryMap).sort((a, b) => b.length - a.length);
    textNodes.forEach(node => {
      const parent = node.parentElement;
      if (!parent || parent.closest('.term-trigger') || parent.closest('.chapter-vocab-preview') || parent.tagName === 'SCRIPT' || parent.tagName === 'STYLE') return;
      let html = node.textContent || '';
      sortedTerms.forEach(term => {
        const regex = new RegExp(`\\b(${term})\\b`, 'g');
        if (regex.test(html)) {
          html = html.replace(regex, `<span class="term-trigger" data-term="$1">$1</span>`);
        }
      });
      if (html !== node.textContent) {
        const span = document.createElement('span');
        span.innerHTML = html;
        parent.replaceChild(span, node);
      }
    });

    articleContent.addEventListener('mouseover', (e) => {
      const trigger = (e.target as HTMLElement).closest('.term-trigger');
      if (trigger) {
        const term = trigger.getAttribute('data-term');
        if (term) showTooltip(term, e.clientX, e.clientY);
      }
    });
    articleContent.addEventListener('mouseout', (e) => {
      const trigger = (e.target as HTMLElement).closest('.term-trigger');
      if (trigger) hideTooltip();
    });
  }
})();


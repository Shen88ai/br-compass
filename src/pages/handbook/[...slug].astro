(function initChecklist() {
  const checklistEl = document.getElementById('3pl-checklist');
  if (!checklistEl) return;

  const checkboxes = checklistEl.querySelectorAll<HTMLInputElement>('.checklist-checkbox');
  const countEl = document.getElementById('checklist-count');
  const resultEl = document.getElementById('checklist-result');
  if (!countEl || !resultEl) return;

  const total = checkboxes.length;
  document.getElementById('checklist-total')!.textContent = String(total);

  checkboxes.forEach(cb => {
    cb.addEventListener('change', () => {
      const checked = checklistEl.querySelectorAll<HTMLInputElement>('.checklist-checkbox:checked').length;
      countEl.textContent = String(checked);

      const pct = Math.round((checked / total) * 100);
      if (pct === 100) {
        resultEl.textContent = '✅ 恭喜！所有檢查項目已完成，可以開始與 3PL 簽約！';
        resultEl.style.color = 'var(--color-neon-green)';

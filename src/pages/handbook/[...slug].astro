        resultEl.style.color = 'var(--color-gold)';
      } else if (pct >= 50) {
        resultEl.textContent = '🟡 已完成一半，繼續加油！';
        resultEl.style.color = 'var(--color-gold-light)';
      } else {
        resultEl.textContent = '🔴 還有很多項目待檢查，請仔細審閱合約';
        resultEl.style.color = 'var(--color-muted)';

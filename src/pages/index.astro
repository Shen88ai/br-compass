---
import Layout from '../layouts/Layout.astro';
import FateWheelScene from '../components/FateWheel/FateWheelScene.astro';
import DiagnosisOverlay from '../components/FateWheel/DiagnosisOverlay.astro';
import PhaseInfoPanel from '../components/FateWheel/PhaseInfoPanel.astro';
---

<Layout title="跨境電商巴西出海實戰手冊" description="從戰略藍圖到利潤收割，最完整的巴西落地指南">
  <!-- 3D Fate Wheel Scene (fixed, always centered) -->
  <FateWheelScene />

  <!-- HTML Overlay Content (scrolls over 3D) -->
  <div class="fate-wheel-overlay">
    <!-- Hero Section -->
    <section class="hero-section-fullscreen">
      <h1 class="hero-title-fate">
        跨境電商出海<span class="text-gradient-hope">巴西</span><br/>實戰手冊
      </h1>
      <p class="hero-subtitle-fate">
        從稅制破譯、公司設立、供應鏈打通到利潤匯出<br/>
        19 篇深度指南，涵蓋外資落地巴西的每一個關鍵節點
      </p>
      <div class="hero-actions-fate animate-on-scroll delay-300">
        <a href="/handbook" class="btn-red btn-md magnetic-btn">📖 瀏覽完整手冊</a>
        <a href="https://braziltax.netlify.app/#contact" class="btn-gold-outline btn-md magnetic-btn">💬 免費咨詢</a>
      </div>
    </section>

    <!-- Diagnosis Overlay (appears after compass interaction) -->
    <DiagnosisOverlay />

    <!-- Phase Info Panel (appears on planet hover) -->
    <PhaseInfoPanel />

    <!-- Phase Overview Cards (scrollable section) -->
    <section class="section-pad section-bg-alt">
      <div class="container">
        <h2 class="section-title">四大實戰<span class="text-gradient-hope">階段</span></h2>
        <p class="section-sub">從籌備到收割，每一步都有詳細指南</p>

        <div class="bento-grid grid-auto-fit">
          <!-- Phase 1 - Featured -->
          <a href="/handbook#phase-preparation" class="bento-featured link-none">
            <div class="bento-card phase-card card-full-height" data-phase="1">
              <div class="phase-icon-sm">🚩</div>
              <div class="phase-label-platinum">階段一 · 第 1~2 個月</div>
              <h3 class="phase-card-title">戰略藍圖與落地籌備</h3>
              <p class="phase-card-desc">破譯巴西稅制、簽證策略、在地團隊組建與授權防護</p>
              <div class="phase-card-link" style="color:var(--color-platinum);">8 篇指南 →</div>
            </div>
          </a>

          <!-- Phase 2 -->
          <a href="/handbook#phase-foundation" class="link-none">
            <div class="bento-card phase-card card-full-height" data-phase="2">
              <div class="phase-icon-sm">🏛️</div>
              <div class="phase-label-blue">階段二 · 第 2~4 個月</div>
              <h3 class="phase-card-title">實體建立與資金血脈</h3>
              <p class="phase-card-desc">CNPJ 申請、Pre-acordo 策略、BACEN 資金申報、平台入駐</p>
              <div class="phase-card-link" style="color:var(--color-gold-light);">3 篇指南 →</div>
            </div>
          </a>

          <!-- Phase 3 -->
          <a href="/handbook#phase-operations" class="link-none">
            <div class="bento-card phase-card card-full-height" data-phase="3">
              <div class="phase-icon-sm">📦</div>
              <div class="phase-label-green">階段三 · 第 4~5 個月</div>
              <h3 class="phase-card-title">供應鏈與數位營運</h3>
              <p class="phase-card-desc">RADAR 申請、3PL 倉儲、ERP 整合、支付系統、售後服務</p>
              <div class="phase-card-link" style="color:var(--color-neon-yellow);">6 篇指南 →</div>
            </div>
          </a>

          <!-- Phase 4 -->
          <a href="/handbook#phase-harvest" class="link-none">
            <div class="bento-card phase-card card-full-height" data-phase="4">
              <div class="phase-icon-sm">💰</div>
              <div class="phase-label-purple">階段四 · 第 6 個月+</div>
              <h3 class="phase-card-title">財務合規與利潤收割</h3>
              <p class="phase-card-desc">日常稅務合規、NF-e、SPED 申報、JCP 抵稅、利潤匯出</p>
              <div class="phase-card-link" style="color:var(--color-neon-green);">3 篇指南 →</div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
      <div class="container-xs">
        <h2 class="heading-xl mb-2">準備好進入<span class="text-gradient-hope">巴西市場</span>了嗎？</h2>
        <p class="text-lg mb-4" style="color:var(--color-muted);line-height:1.6;">
          從手冊開始，或直接聯繫我們的巴西稅務專家團隊<br/>
          獲取一對一的落地策略諮詢
        </p>
        <div class="hero-actions">
          <a href="/handbook" class="btn-red btn-md magnetic-btn">📖 閱讀手冊</a>
          <a href="https://braziltax.netlify.app/#contact" class="btn-outline btn-md magnetic-btn">聯繫專家</a>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .hero-section-fullscreen {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-5) var(--space-3);
    position: relative;
    z-index: 10;
  }

  .hero-title-fate {
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: var(--space-3);
    text-shadow: 0 0 40px rgba(0, 0, 0, 0.8);
  }

  .hero-subtitle-fate {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--color-muted);
    max-width: 650px;
    margin: 0 auto var(--space-4);
    line-height: 1.7;
    text-shadow: 0 0 20px rgba(0, 0, 0, 0.6);
  }

  .hero-actions-fate {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }

  section a:hover .card {
    border-color: rgba(var(--color-gold-rgb, 212, 168, 67), 0.5);
    box-shadow: 0 12px 40px rgba(var(--color-gold-rgb, 212, 168, 67), 0.15);
  }
</style>

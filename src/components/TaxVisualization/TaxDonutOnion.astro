  font-size: 1rem;
  font-weight: 700;
  font-family: var(--font-mono, monospace);
}

.onion-formula {
  margin-top: 1.5rem;
  padding: 1rem;
  background: rgba(0, 255, 135, 0.05);
  border: 1px solid rgba(0, 255, 135, 0.2);
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
}

.formula-badge {
  font-size: 0.85rem;
  color: var(--color-neon-green, #00FF87);
  font-weight: 600;
}

.onion-formula code {
  font-family: var(--font-mono, monospace);
  font-size: 0.9rem;
  color: var(--color-text-muted, #B8BCC8);
  background: rgba(0, 0, 0, 0.3);
  padding: 0.25rem 0.5rem;
  border-radius: 4px;
}
</style>

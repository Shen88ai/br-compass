  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.85rem;
}

.breakdown-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}

.breakdown-label {
  flex: 1;
  color: var(--color-text-muted, #B8BCC8);
}

.breakdown-value {
  font-weight: 600;
  font-family: var(--font-mono, monospace);
}

.viz-cbs-onion {
  margin-top: 1.5rem;
  padding-top: 1.5rem;
  border-top: 1px solid rgba(212, 168, 67, 0.15);
}

.onion-title {
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--color-neon-yellow, #E5FF00);
  margin: 0 0 1rem;
}

.onion-layers {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.onion-layer {
  display: flex;
  align-items: center;

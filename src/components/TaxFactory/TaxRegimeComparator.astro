---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={["tax-regime-comparator", className]}>
  <h3 class="comparator-title">🇧🇷 進口商品稅務決策流程</h3>
  
  <div class="input-section">
    <h4 class="section-title">💡 互動式模擬試算</h4>
    <div class="input-grid">
      <div class="input-group">
        <label for="annual-revenue">年度營業額 (R$/年):</label>
        <input type="text" id="annual-revenue" class="money-input" placeholder="例如: 5000000" value="100000" />
      </div>
      <div class="input-group">
        <label for="cif-value">進口貨值 CIF (R$):</label>
        <input type="text" id="cif-value" class="money-input" placeholder="例如: 100000" value="50000" />
      </div>
    </div>
  </div>

  <div class="step-container">
    <div class="step" data-step="1">
      <h4 class="step-title">Step 1 / 選擇稅務套裝 (Regime & PIS/COFINS)</h4>
      <div class="regime-options">
        <label class="regime-option">
          <input type="radio" name="tax-regime" value="simples" />
          <div class="regime-card">
            <span class="regime-name">Simples Nacional</span>
            <span class="regime-desc">適合小微企業 / PIS/COFINS 已含於單一稅率</span>
          </div>
        </label>
        <label class="regime-option">
          <input type="radio" name="tax-regime" value="presumido-cumulativo" />
          <div class="regime-card">
            <span class="regime-name">Lucro Presumido (累積制)</span>
            <span class="regime-desc">法律強制 / PIS 0.65% / COFINS 3.0%</span>
          </div>
        </label>
        <label class="regime-option">
          <input type="radio" name="tax-regime" value="real-nao-cumulativo" />
          <div class="regime-card">
            <span class="regime-name">Lucro Real (非累積制)</span>
            <span class="regime-desc">一般大型企業 / PIS 1.65% / COFINS 7.6% (可抵扣)</span>
          </div>
        </label>
        <label class="regime-option">
          <input type="radio" name="tax-regime" value="real-cumulativo" />
          <div class="regime-card">
            <span class="regime-name">Lucro Real (累積制)</span>
            <span class="regime-desc">特定行業 / PIS 3.65% / COFINS 3.65% (無抵扣)</span>
          </div>
        </label>
      </div>
    </div>

    <div class="step" data-step="2">
      <h4 class="step-title">Step 2 / 第二層：Adicional do IRPJ</h4>
      <p class="step-desc">當年度 Lucro Real / Presumido 超過 R$20,000/月（年化 R$240,000）時，IRPJ 須加收 10% 附加稅</p>
      <div class="adicional-options">
        <label class="regime-option">
          <input type="radio" name="adicional" value="yes" />
          <div class="regime-card">
            <span class="regime-name">✅ 適用 Adicional</span>
            <span class="regime-desc">lucro > R$240k/年時加徵 10%</span>
          </div>
        </label>
        <label class="regime-option">
          <input type="radio" name="adicional" value="no" checked />
          <div class="regime-card">
            <span class="regime-name">❌ 不適用 Adicional</span>
            <span class="regime-desc">利潤未超過門檻</span>
          </div>
        </label>
      </div>
    </div>

    <div class="step" data-step="3">
      <h4 class="step-title">Step 3 / 進口稅率設定 (Tributos na Importação)</h4>
      <div class="step-3-layout">
        <div class="import-rate-dropdown">
          <label for="ncm-rate">II 稅率 (%) - 依 NCM:</label>
          <select id="ncm-rate" class="tax-select">
            <option value="10">10% - 一般電子產品</option>
            <option value="15">15% - 紡織品/家具</option>
            <option value="20" selected>20% - 電器/機械</option>
            <option value="35">35% - 奢侈品/汽機車</option>
          </select>
          <div class="other-rates">
            <div class="input-group">
              <label>IPI (%):</label>
              <input type="number" id="ipi-rate" value="10" />
            </div>
            <div class="input-group">
              <label>ICMS (%):</label>
              <input type="number" id="icms-rate" value="18" />
            </div>
          </div>
        </div>
        <div class="result-card-display" id="result-card-display">
        </div>
      </div>
    </div>
  </div>

  <div class="reform-toggle">
    <label>
      <input type="checkbox" id="enable-reform" />
      <span>🎯 啟動 2026 稅改過渡期模擬 (Reforma Tributária)</span>
    </label>
    <p class="reform-note">PIS/COFINS 將自動全員抵扣 1% 並獨立為 CBS (0.9%) 及 IBS (0.1%)</p>
  </div>

  <p class="disclaimer">⚠️ 免责声明：此模拟试算只是为了学习，如有业务需求请咨询专业税务会计师</p>
</div>

<style>
.tax-regime-comparator {
  background: linear-gradient(135deg, rgba(13, 13, 20, 0.98) 0%, rgba(20, 20, 35, 0.98) 100%);
  border: 2px solid rgba(212, 168, 67, 0.3);
  border-radius: 16px;
  padding: 1.5rem;
  margin: 2rem 0;
  font-family: var(--font-sans), 'Inter', ui-sans-serif, system-ui, sans-serif;
}

.comparator-title {
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--color-gold, #D4A843);
  margin: 0 0 1.5rem 0;
  text-align: center;
}

.step {
  margin-bottom: 1.5rem;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid rgba(212, 168, 67, 0.2);
}

.step-title {
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-text, #F5F5F0);
  margin: 0 0 0.75rem 0;
}

.step-desc {
  font-size: 0.85rem;
  color: var(--color-text-muted, #B8BCC8);
  margin: 0 0 0.75rem 0;
}

.regime-options {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 0.75rem;
}

.regime-option input {
  display: none;
}

.regime-card {
  background: rgba(26, 26, 36, 0.9);
  border: 2px solid rgba(212, 168, 67, 0.2);
  border-radius: 12px;
  padding: 1rem;
  cursor: pointer;
  transition: all 0.2s ease;
}

.regime-option input:checked + .regime-card {
  border-color: #D4A843;
  background: rgba(212, 168, 67, 0.15);
}

.regime-card:hover {
  border-color: rgba(212, 168, 67, 0.5);
}

.regime-name {
  display: block;
  font-weight: 600;
  color: #F5F5F0;
  margin-bottom: 0.25rem;
}

.regime-desc {
  display: block;
  font-size: 0.75rem;
  color: #888;
}

.adicional-options {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0.75rem;
}

.adicional-option {
  display: none;
}

.input-section {
  margin-bottom: 1.5rem;
}

.section-title {
  font-size: 1rem;
  font-weight: 600;
  color: #D4A843;
  margin: 0 0 1rem 0;
}

.input-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
}

.input-group {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.input-group label {
  font-size: 0.85rem;
  color: #888;
}

.money-input {
  background: #1a1a24;
  border: 1px solid #333;
  color: #f5f5f0;
  padding: 0.75rem 1rem;
  border-radius: 8px;
  font-size: 1rem;
}

.money-input:focus {
  outline: none;
  border-color: #D4A843;
}

.reform-toggle {
  background: rgba(125, 211, 252, 0.1);
  border: 1px solid #7DD3FC;
  border-radius: 8px;
  padding: 1rem;
  margin-bottom: 1.5rem;
}

.reform-toggle label {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  cursor: pointer;
  color: #7DD3FC;
}

.reform-toggle input {
  accent-color: #7DD3FC;
}

.reform-note {
  font-size: 0.75rem;
  color: #888;
  margin: 0.5rem 0 0 0;
}

.tax-breakdown {
  background: rgba(26, 26, 36, 0.9);
  border: 1px solid rgba(212, 168, 67, 0.2);
  border-radius: 12px;
  padding: 1rem;
  margin-bottom: 1.5rem;
}

.breakdown-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1rem;
}

.breakdown-regime {
  font-weight: 600;
  color: #D4A843;
}

.breakdown-note {
  font-size: 0.75rem;
  color: #00FF87;
}

.breakdown-section {
  margin-bottom: 1rem;
}

.breakdown-section-title {
  font-weight: 600;
  color: #7DD3FC;
  margin: 0 0 0.5rem 0;
}

.breakdown-row {
  display: flex;
  justify-content: space-between;
  padding: 0.25rem 0;
  font-size: 0.85rem;
}

.breakdown-row .label {
  color: #888;
  flex-shrink: 0;
}

.breakdown-row .value {
  color: #F5F5F0;
  text-align: right;
  flex-shrink: 0;
}

.breakdown-total {
  display: flex;
  justify-content: space-between;
  padding: 0.5rem 0;
  font-weight: 700;
  color: #D4A843;
  border-top: 1px solid #D4A843;
  margin-top: 0.5rem;
}

.breakdown-total .value {
  text-align: right;
}

.disclaimer {
  font-size: 0.75rem;
  color: #666;
  text-align: center;
  font-style: italic;
}

@media (max-width: 600px) {
  .input-grid {
    grid-template-columns: 1fr;
  }
  
  .regime-options {
    grid-template-columns: 1fr;
  }
  
  .adicional-options {
    flex-direction: column;
    gap: 0.75rem;
  }
}

.step-3-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
}

.import-rate-dropdown {
  background: rgba(26, 26, 36, 0.9);
  border: 1px solid rgba(212, 168, 67, 0.2);
  border-radius: 12px;
  padding: 1rem;
}

.import-rate-dropdown label {
  display: block;
  font-size: 0.85rem;
  color: #888;
  margin-bottom: 0.5rem;
}

.tax-select {
  width: 100%;
  background: #1a1a24;
  border: 1px solid #333;
  color: #f5f5f0;
  padding: 0.75rem;
  border-radius: 8px;
  font-size: 0.9rem;
  margin-bottom: 1rem;
  cursor: pointer;
}

.tax-select:focus {
  outline: none;
  border-color: #D4A843;
}

.other-rates {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.75rem;
}

.other-rates .input-group {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.other-rates .input-group label {
  font-size: 0.75rem;
  color: #888;
}

.other-rates .input-group input {
  background: #0a0a0f;
  border: 1px solid #333;
  color: #f5f5f0;
  padding: 0.5rem;
  border-radius: 4px;
  font-size: 0.85rem;
}

.result-card-display {
  background: rgba(13, 13, 20, 0.95);
  border: 1px solid rgba(0, 255, 135, 0.2);
  border-radius: 12px;
  padding: 1rem;
  min-height: 200px;
}

.result-card-display .breakdown-row {
  display: flex;
  justify-content: space-between;
}

.result-card-display .breakdown-row .label {
  flex-shrink: 0;
}

.result-card-display .breakdown-row .value {
  text-align: right;
  flex-shrink: 0;
}

.result-card-display .breakdown-total {
  display: flex;
  justify-content: space-between;
}

.result-card-display .breakdown-total .value {
  text-align: right;
}

@media (max-width: 768px) {
  .step-3-layout {
    grid-template-columns: 1fr;
  }
}
</style>

<script>
const REGIME_DATA = {
  'simples': {
    name: 'Simples Nacional',
    rate: 0.06,
    formula: 'DAS = RB × 6%',
    pis: 0,
    cofins: 0,
    note: 'ℹ️ Simples Nacional 不適用 Adicional IRPJ，IRPJ/CSLL 已含於 DAS。'
  },
  'presumido-cumulativo': {
    name: 'Lucro Presumido (累積制)',
    rate: 0.0365,
    formula: 'PIS = RB × 0.65% / COFINS = RB × 3%',
    pis: 0.0065,
    cofins: 0.03
  },
  'real-nao-cumulativo': {
    name: 'Lucro Real (非累積制)',
    rate: 0.0915,
    formula: 'IRPJ/CSLL (實際) + PIS/COFINS (可抵扣)',
    pis: 0.0165,
    cofins: 0.076
  },
  'real-cumulativo': {
    name: 'Lucro Real (累積制)',
    rate: 0.073,
    formula: 'PIS = RB × 3.65% / COFINS = RB × 3.65% (無抵扣)',
    pis: 0.0365,
    cofins: 0.0365
  }
};

const PIS_IMPORT = 0.021;
const COFINS_IMPORT = 0.0965;
const CBS_RATE = 0.009;
const IBS_RATE = 0.001;
const GROSS_MARGIN = 0.30;
const CREDIT_RATIO = 0.50;

function formatMoney(value: number): string {
  return 'R$ ' + value.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function parseMoney(value: string): number {
  if (!value) return 0;
  const cleaned = value.replace(/R\$\s/g, '').replace(/\./g, '').replace(/,/g, '.');
  return parseFloat(cleaned) || 0;
}

function calculateImportTax(cif: number, ncmRate: number, ipiRate: number, icmsRate: number) {
  const ii = cif * (ncmRate / 100);
  const baseIpi = cif + ii;
  const ipi = baseIpi * (ipiRate / 100);
  const pis = cif * PIS_IMPORT;
  const cofins = cif * COFINS_IMPORT;
  const baseIcms = cif + ii + ipi + pis + cofins;
  const icms = baseIcms / (1 - icmsRate / 100) * (icmsRate / 100);
  
  return { ii, ipi, pis, cofins, icms, total: ii + ipi + pis + cofins + icms };
}

function updateCalculation() {
  const revenueInput = document.getElementById('annual-revenue') as HTMLInputElement;
  const cifInput = document.getElementById('cif-value') as HTMLInputElement;
  const reformCheckbox = document.getElementById('enable-reform') as HTMLInputElement;
  const resultCardDisplay = document.getElementById('result-card-display');
  
  if (!revenueInput || !cifInput) return;
  
  const revenue = parseMoney(revenueInput.value);
  const cif = parseMoney(cifInput.value);
  const useReform = reformCheckbox?.checked || false;
  
  const ncmSelect = document.getElementById('ncm-rate') as HTMLSelectElement;
  const ncmRate = ncmSelect ? parseFloat(ncmSelect.value) : 20;
  const ipiRate = parseFloat((document.getElementById('ipi-rate') as HTMLInputElement)?.value) || 10;
  const icmsRate = parseFloat((document.getElementById('icms-rate') as HTMLInputElement)?.value) || 18;
  
  const adicionalesYes = (document.querySelector('input[name="adicional"]:checked') as HTMLInputElement)?.value === 'yes';
  const profit = revenue * GROSS_MARGIN;
  const adicionalAmount = adicionalesYes && profit > 240000 ? (profit - 240000) * 0.10 : 0;
  
  const importTax = calculateImportTax(cif, ncmRate, ipiRate, icmsRate);
  
  const selectedRegimeEl = document.querySelector('input[name="tax-regime"]:checked') as HTMLInputElement;
  const selectedRegime = selectedRegimeEl?.value || null;
  
  let html = '';
  
  if (!selectedRegime) {
    if (resultCardDisplay) {
      resultCardDisplay.innerHTML = '<p style="color:#666;text-align:center;padding:2rem;">請先選擇稅務套裝</p>';
    }
    return;
  }
  
  Object.entries(REGIME_DATA).forEach(([key, data]) => {
    if (key !== selectedRegime) return;
    
    let domesticRows = '';
    let domesticTotal = 0;
    let importPis = importTax.pis;
    let importCofins = importTax.cofins;
    let reformSavings = 0;
    
    if (key === 'simples') {
      const das = revenue * data.rate;
      domesticTotal = das;
      domesticRows = `
        <div class="breakdown-row">
          <span class="label">DAS (6%):</span>
          <span class="value">${formatMoney(das)}</span>
        </div>
      `;
    } else if (key.includes('presumido')) {
      const pisBr = revenue * data.pis;
      const cofinsBr = revenue * data.cofins;
      const irpj = profit * 0.15;
      const csll = profit * 0.09;
      const adicional = adicionalAmount;
      domesticTotal = pisBr + cofinsBr + irpj + csll + adicional;
      domesticRows = `
        <div class="breakdown-row">
          <span class="label">PIS (0.65%):</span>
          <span class="value">${formatMoney(pisBr)}</span>
        </div>
        <div class="breakdown-row">
          <span class="label">COFINS (3%):</span>
          <span class="value">${formatMoney(cofinsBr)}</span>
        </div>
        <div class="breakdown-row">
          <span class="label">IRPJ (15%):</span>
          <span class="value">${formatMoney(irpj)}</span>
        </div>
        <div class="breakdown-row">
          <span class="label">CSLL (9%):</span>
          <span class="value">${formatMoney(csll)}</span>
        </div>
        ${adicional > 0 ? `
        <div class="breakdown-row">
          <span class="label">Adicional IRPJ (10%):</span>
          <span class="value">${formatMoney(adicional)}</span>
        </div>
        ` : ''}
      `;
      if (useReform) {
        reformSavings = revenue * 0.01;
        importPis -= reformSavings * (importTax.pis / (importTax.pis + importTax.cofins));
        importCofins -= reformSavings * (importTax.cofins / (importTax.pis + importTax.cofins));
      }
    } else if (key.includes('real-nao-cumulativo')) {
      const pisBr = revenue * data.pis;
      const cofinsBr = revenue * data.cofins;
      const irpj = profit * 0.15;
      const csll = profit * 0.09;
      const adicional = adicionalAmount;
      const creditablePis = revenue * data.pis * CREDIT_RATIO;
      const creditableCofins = revenue * data.cofins * CREDIT_RATIO;
      domesticTotal = pisBr + cofinsBr + irpj + csll + adicional - creditablePis - creditableCofins;
      domesticRows = `
        <div class="breakdown-row">
          <span class="label">PIS (1.65%):</span>
          <span class="value">${formatMoney(pisBr)}</span>
        </div>
        <div class="breakdown-row">
          <span class="label">COFINS (7.6%):</span>
          <span class="value">${formatMoney(cofinsBr)}</span>
        </div>
        <div class="breakdown-row">
          <span class="label">IRPJ (15%):</span>
          <span class="value">${formatMoney(irpj)}</span>
        </div>
        <div class="breakdown-row">
          <span class="label">CSLL (9%):</span>
          <span class="value">${formatMoney(csll)}</span>
        </div>
        ${adicional > 0 ? `
        <div class="breakdown-row">
          <span class="label">Adicional IRPJ (10%):</span>
          <span class="value">${formatMoney(adicional)}</span>
        </div>
        ` : ''}
        <div class="breakdown-row">
          <span class="label" style="color:#00FF87">可抵扣 PIS (-50%):</span>
          <span class="value" style="color:#00FF87">-${formatMoney(creditablePis)}</span>
        </div>
        <div class="breakdown-row">
          <span class="label" style="color:#00FF87">可抵扣 COFINS (-50%):</span>
          <span class="value" style="color:#00FF87">-${formatMoney(creditableCofins)}</span>
        </div>
      `;
      if (useReform) {
        reformSavings = revenue * 0.01;
        importPis -= reformSavings * 0.21 / 1.165;
        importCofins -= reformSavings * 0.965 / 1.165;
      }
    } else if (key.includes('real-cumulativo')) {
      const pisBr = revenue * data.pis;
      const cofinsBr = revenue * data.cofins;
      const irpj = profit * 0.15;
      const csll = profit * 0.09;
      const adicional = adicionalAmount;
      domesticTotal = pisBr + cofinsBr + irpj + csll + adicional;
      domesticRows = `
        <div class="breakdown-row">
          <span class="label">PIS (3.65%):</span>
          <span class="value">${formatMoney(pisBr)}</span>
        </div>
        <div class="breakdown-row">
          <span class="label">COFINS (3.65%):</span>
          <span class="value">${formatMoney(cofinsBr)}</span>
        </div>
        <div class="breakdown-row">
          <span class="label">IRPJ (15%):</span>
          <span class="value">${formatMoney(irpj)}</span>
        </div>
        <div class="breakdown-row">
          <span class="label">CSLL (9%):</span>
          <span class="value">${formatMoney(csll)}</span>
        </div>
        ${adicional > 0 ? `
        <div class="breakdown-row">
          <span class="label">Adicional IRPJ (10%):</span>
          <span class="value">${formatMoney(adicional)}</span>
        </div>
        ` : ''}
      `;
      if (useReform) {
        reformSavings = revenue * 0.01;
        importPis -= reformSavings * 0.21 / 1.165;
        importCofins -= reformSavings * 0.965 / 1.165;
      }
    }
    
    const newImportPis = importPis < 0 ? 0 : importPis;
    const newImportCofins = importCofins < 0 ? 0 : importCofins;
    const importTotalWithReform = importTax.ii + importTax.ipi + newImportPis + newImportCofins + importTax.icms;
    const grandTotal = domesticTotal + importTotalWithReform;
    
    let reformRow = '';
    if (useReform) {
      reformRow = `
        <div class="breakdown-row">
          <span class="label">📉 稅改抵扣 (1%):</span>
          <span class="value" style="color:#00FF87">-${formatMoney(reformSavings)}</span>
        </div>
      `;
    }
    
    html += `
      <div class="tax-breakdown">
        <div class="breakdown-header">
          <span class="breakdown-regime">${data.name}</span>
        </div>
        ${data.note ? `<p class="breakdown-note">${data.note}</p>` : ''}
        
        <div class="breakdown-section">
          <div class="breakdown-section-title">🇧🇷 國內環節 (Brasil)</div>
          ${domesticRows}
          <div class="breakdown-row" style="border-top:1px solid #333;margin-top:0.5rem;padding-top:0.5rem">
            <span class="label" style="font-weight:600">國內稅合計:</span>
            <span class="value" style="font-weight:600">${formatMoney(domesticTotal)}</span>
          </div>
        </div>
        
        <div class="breakdown-section">
          <div class="breakdown-section-title">🛃 進口環節 (Importação)</div>
          <div class="breakdown-row">
            <span class="label">II (${ncmRate}%):</span>
            <span class="value">${formatMoney(importTax.ii)}</span>
          </div>
          <div class="breakdown-row">
            <span class="label">IPI (${ipiRate}%):</span>
            <span class="value">${formatMoney(importTax.ipi)}</span>
          </div>
          <div class="breakdown-row">
            <span class="label">ICMS (${icmsRate}%):</span>
            <span class="value">${formatMoney(importTax.icms)}</span>
          </div>
          <div class="breakdown-row">
            <span class="label">PIS Imp. (2.1%):</span>
            <span class="value">${formatMoney(newImportPis)}</span>
          </div>
          <div class="breakdown-row">
            <span class="label">COFINS Imp. (9.65%):</span>
            <span class="value">${formatMoney(newImportCofins)}</span>
          </div>
          ${reformRow}
          <div class="breakdown-row" style="border-top:1px solid #333;margin-top:0.5rem;padding-top:0.5rem">
            <span class="label" style="font-weight:600">進口稅合計:</span>
            <span class="value" style="font-weight:600">${formatMoney(importTotalWithReform)}</span>
          </div>
        </div>
        
        <div class="breakdown-total">
          <span>總計:</span>
          <span>${formatMoney(grandTotal)}</span>
        </div>
      </div>
    `;
  });
  
  if (resultCardDisplay) {
    if (html) {
      resultCardDisplay.innerHTML = html;
    } else {
      resultCardDisplay.innerHTML = '<p style="color:#666;text-align:center;padding:2rem;">請先選擇稅務套裝</p>';
    }
  }
}

document.addEventListener('DOMContentLoaded', () => {
  const revenueInput = document.getElementById('annual-revenue');
  const cifInput = document.getElementById('cif-value');
  const reformCheckbox = document.getElementById('enable-reform');
  const ipiInput = document.getElementById('ipi-rate');
  const icmsInput = document.getElementById('icms-rate');
  const adicionalInputs = document.querySelectorAll('input[name="adicional"]');
  const regimeInputs = document.querySelectorAll('input[name="tax-regime"]');
  const ncmSelect = document.getElementById('ncm-rate');
  
  [revenueInput, cifInput, ipiInput, icmsInput].forEach(input => {
    input?.addEventListener('input', updateCalculation);
  });
  
  adicionalInputs.forEach(input => {
    input?.addEventListener('change', updateCalculation);
  });
  
  regimeInputs.forEach(input => {
    input?.addEventListener('change', updateCalculation);
  });
  
  ncmSelect?.addEventListener('change', updateCalculation);
  
  reformCheckbox?.addEventListener('change', updateCalculation);
  
  updateCalculation();
});
</script>
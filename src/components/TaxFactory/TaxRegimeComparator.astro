.step-3-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
}

.import-rate-dropdown {
  background: rgba(26, 26, 36, 0.9);
  border: 1px solid rgba(212, 168, 67, 0.2);
  border-radius: 12px;
  padding: 1rem;
}

.import-rate-dropdown label {
  display: block;
  font-size: 0.85rem;
  color: #888;
  margin-bottom: 0.5rem;
}

.tax-select {
  width: 100%;
  background: #1a1a24;
  border: 1px solid #333;
  color: #f5f5f0;
  padding: 0.75rem;
  border-radius: 8px;
  font-size: 0.9rem;
  margin-bottom: 1rem;
  cursor: pointer;
}

.tax-select:focus {
  outline: none;
  border-color: #D4A843;
}

.other-rates {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.75rem;
}

.other-rates .input-group {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.other-rates .input-group label {
  font-size: 0.75rem;
  color: #888;
}

.other-rates .input-group input {
  background: #0a0a0f;
  border: 1px solid #333;
  color: #f5f5f0;
  padding: 0.5rem;
  border-radius: 4px;
  font-size: 0.85rem;
}

.result-card-display {
  background: rgba(13, 13, 20, 0.95);
  border: 1px solid rgba(0, 255, 135, 0.2);
  border-radius: 12px;
  padding: 1rem;
  min-height: 200px;
}

@media (max-width: 768px) {
  .step-3-layout {
    grid-template-columns: 1fr;
  }
}
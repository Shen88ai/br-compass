---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={["tax-regime-comparator", className]}>
  <h3 class="comparator-title">🇧🇷 稅務決策流程</h3>
  
  <div class="step-container">
    <div class="step" data-step="1">
      <h4 class="step-title">Step 1 / 選擇稅務套裝 (Regime & PIS/COFINS)</h4>
      <div class="regime-options">
        <label class="regime-option">
          <input type="radio" name="tax-regime" value="simples" />
          <div class="regime-card">
            <span class="regime-name">Simples Nacional</span>
            <span class="regime-desc">適合小微企業 / PIS/COFINS 已含於單一稅率</span>
          </div>
        </label>
        <label class="regime-option">
          <input type="radio" name="tax-regime" value="presumido-cumulativo" />
          <div class="regime-card">
            <span class="regime-name">Lucro Presumido (累積制)</span>
            <span class="regime-desc">法律強制 / PIS 0.65% / COFINS 3.0%</span>
          </div>
        </label>
        <label class="regime-option">
          <input type="radio" name="tax-regime" value="real-nao-cumulativo" />
          <div class="regime-card">
            <span class="regime-name">Lucro Real (非累積制)</span>
            <span class="regime-desc">一般大型企業 / PIS 1.65% / COFINS 7.6% (可抵扣)</span>
          </div>
        </label>
        <label class="regime-option">
          <input type="radio" name="tax-regime" value="real-cumulativo" />
          <div class="regime-card">
            <span class="regime-name">Lucro Real (累積制)</span>
            <span class="regime-desc">特定行業 / PIS 3.65% / COFINS 3.65% (無抵扣)</span>
          </div>
        </label>
      </div>
    </div>

    <div class="step" data-step="2">
      <h4 class="step-title">Step 2 / 第二層：Adicional do IRPJ</h4>
      <p class="step-desc">當年度 Lucro Real / Presumido 超過 R$20,000/月（年化 R$240,000）時，IRPJ 須加收 10% 附加稅</p>
      <div class="adicional-options">
        <label class="adicional-option">
          <input type="radio" name="adicional" value="yes" />
          <span>✅ 適用 Adicional (lucro > R$240k/年)</span>
        </label>
        <label class="adicional-option">
          <input type="radio" name="adicional" value="no" checked />
          <span>❌ 不適用 Adicional</span>
        </label>
      </div>
    </div>
  </div>

  <div class="input-section">
    <h4 class="section-title">💡 互動式模擬試算</h4>
    <div class="input-grid">
      <div class="input-group">
        <label for="annual-revenue">年度營業額 (R$/年):</label>
        <input type="text" id="annual-revenue" class="money-input" placeholder="例如: 5000000" value="5000000" />
      </div>
      <div class="input-group">
        <label for="cif-value">進口貨值 CIF (R$):</label>
        <input type="text" id="cif-value" class="money-input" placeholder="例如: 100000" value="100000" />
      </div>
    </div>
  </div>

  <div class="reform-toggle">
    <label>
      <input type="checkbox" id="enable-reform" />
      <span>🎯 啟動 2026 稅改��渡期模擬 (Reforma Tributária)</span>
    </label>
    <p class="reform-note">PIS/COFINS 將自動全員抵扣 1% 並獨立為 CBS (0.9%) 及 IBS (0.1%)</p>
  </div>

  <div class="results-section">
    <h4 class="results-title">📊 計算結果</h4>
    <div class="results-table">
      <table>
        <thead>
          <tr>
            <th>制度</th>
            <th>稅金組成與計算公式</th>
            <th>年度預估合計</th>
          </tr>
        </thead>
        <tbody id="results-body">
        </tbody>
      </table>
    </div>
  </div>

  <div class="import-tax-section">
    <h4 class="section-title">🛃 進口稅計算 - Tributos na Importação</h4>
    <div class="import-tax-grid">
      <div class="import-input-row">
        <div class="import-input-group">
          <label>NCM 稅率 (%):</label>
          <input type="number" id="ncm-rate" value="10" />
        </div>
        <div class="import-input-group">
          <label>IPI 稅率 (%):</label>
          <input type="number" id="ipi-rate" value="10" />
        </div>
        <div class="import-input-group">
          <label>ICMS 稅率 (%):</label>
          <input type="number" id="icms-rate" value="18" />
        </div>
      </div>
      <div class="import-results" id="import-results">
        <div class="tax-row"><span>II (關稅):</span><span class="tax-value" id="tax-ii">0</span></div>
        <div class="tax-row"><span>IPI:</span><span class="tax-value" id="tax-ipi">0</span></div>
        <div class="tax-row"><span>PIS Importação:</span><span class="tax-value" id="tax-pis">0</span></div>
        <div class="tax-row"><span>COFINS Importação:</span><span class="tax-value" id="tax-cofins">0</span></div>
        <div class="tax-row"><span>ICMS:</span><span class="tax-value" id="tax-icms">0</span></div>
        <div class="tax-row total"><span>進口稅合計:</span><span class="tax-value" id="tax-total">0</span></div>
      </div>
    </div>
  </div>

  <p class="disclaimer">⚠️ 免責聲明：此模擬試算只是為了學習，如有業務需求請諮詢專業稅務會計師</p>
</div>

<style>
.tax-regime-comparator {
  background: linear-gradient(135deg, rgba(13, 13, 20, 0.98) 0%, rgba(20, 20, 35, 0.98) 100%);
  border: 2px solid rgba(212, 168, 67, 0.3);
  border-radius: 16px;
  padding: 1.5rem;
  margin: 2rem 0;
  font-family: var(--font-sans), 'Inter', ui-sans-serif, system-ui, sans-serif;
}

.comparator-title {
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--color-gold, #D4A843);
  margin: 0 0 1.5rem 0;
  text-align: center;
}

.step {
  margin-bottom: 1.5rem;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid rgba(212, 168, 67, 0.2);
}

.step-title {
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-text, #F5F5F0);
  margin: 0 0 0.75rem 0;
}

.step-desc {
  font-size: 0.85rem;
  color: var(--color-text-muted, #B8BCC8);
  margin: 0 0 0.75rem 0;
}

.regime-options {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 0.75rem;
}

.regime-option input {
  display: none;
}

.regime-card {
  background: rgba(26, 26, 36, 0.9);
  border: 2px solid rgba(212, 168, 67, 0.2);
  border-radius: 12px;
  padding: 1rem;
  cursor: pointer;
  transition: all 0.2s ease;
}

.regime-option input:checked + .regime-card {
  border-color: #D4A843;
  background: rgba(212, 168, 67, 0.15);
}

.regime-card:hover {
  border-color: rgba(212, 168, 67, 0.5);
}

.regime-name {
  display: block;
  font-weight: 600;
  color: #F5F5F0;
  margin-bottom: 0.25rem;
}

.regime-desc {
  display: block;
  font-size: 0.75rem;
  color: #888;
}

.adicional-options {
  display: flex;
  gap: 1.5rem;
}

.adicional-option {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  cursor: pointer;
}

.adicional-option input {
  accent-color: #D4A843;
}

.input-section {
  margin-bottom: 1.5rem;
}

.section-title {
  font-size: 1rem;
  font-weight: 600;
  color: #D4A843;
  margin: 0 0 1rem 0;
}

.input-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
}

.input-group {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.input-group label {
  font-size: 0.85rem;
  color: #888;
}

.money-input {
  background: #1a1a24;
  border: 1px solid #333;
  color: #f5f5f0;
  padding: 0.75rem 1rem;
  border-radius: 8px;
  font-size: 1rem;
}

.money-input:focus {
  outline: none;
  border-color: #D4A843;
}

.reform-toggle {
  background: rgba(125, 211, 252, 0.1);
  border: 1px solid #7DD3FC;
  border-radius: 8px;
  padding: 1rem;
  margin-bottom: 1.5rem;
}

.reform-toggle label {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  cursor: pointer;
  color: #7DD3FC;
}

.reform-toggle input {
  accent-color: #7DD3FC;
}

.reform-note {
  font-size: 0.75rem;
  color: #888;
  margin: 0.5rem 0 0 0;
}

.results-section {
  margin-bottom: 1.5rem;
}

.results-title {
  font-size: 1rem;
  font-weight: 600;
  color: #D4A843;
  margin: 0 0 1rem 0;
}

.results-table {
  overflow-x: auto;
}

.results-table table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.85rem;
}

.results-table th,
.results-table td {
  padding: 0.75rem;
  text-align: left;
  border-bottom: 1px solid rgba(212, 168, 67, 0.2);
}

.results-table th {
  color: #D4A843;
  font-weight: 600;
}

.results-table td:last-child {
  text-align: right;
  font-weight: 600;
  color: #00FF87;
}

.import-tax-section {
  background: rgba(26, 26, 36, 0.9);
  border: 1px solid rgba(212, 168, 67, 0.2);
  border-radius: 12px;
  padding: 1rem;
  margin-bottom: 1.5rem;
}

.import-tax-grid {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.import-input-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.75rem;
}

.import-input-group {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.import-input-group label {
  font-size: 0.75rem;
  color: #888;
}

.import-input-group input {
  background: #0a0a0f;
  border: 1px solid #333;
  color: #f5f5f0;
  padding: 0.5rem;
  border-radius: 4px;
}

.import-results {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.tax-row {
  display: flex;
  justify-content: space-between;
  padding: 0.25rem 0;
  font-size: 0.85rem;
}

.tax-row.total {
  font-weight: 700;
  color: #D4A843;
  border-top: 1px solid #D4A843;
  margin-top: 0.5rem;
  padding-top: 0.5rem;
}

.disclaimer {
  font-size: 0.75rem;
  color: #666;
  text-align: center;
  font-style: italic;
}

@media (max-width: 600px) {
  .input-grid,
  .import-input-row {
    grid-template-columns: 1fr;
  }
  
  .regime-options {
    grid-template-columns: 1fr;
  }
  
  .adicional-options {
    flex-direction: column;
    gap: 0.75rem;
  }
}
</style>

<script>
const REGIME_DATA = {
  'simples': {
    name: 'Simples Nacional',
    rate: 0.06,
    formula: 'DAS = RB × 6%',
    pis: 0,
    cofins: 0
  },
  'presumido-cumulativo': {
    name: 'Lucro Presumido (累積制)',
    rate: 0.0365,
    formula: 'PIS = RB × 0.65% / COFINS = RB × 3% / IRPJ/CSLL (預估)',
    pis: 0.0065,
    cofins: 0.03
  },
  'real-nao-cumulativo': {
    name: 'Lucro Real (非累積制)',
    rate: 0.0915,
    formula: '依所選模式計算 / IRPJ/CSLL (實際按30%毛利估算)',
    pis: 0.0165,
    cofins: 0.076
  },
  'real-cumulativo': {
    name: 'Lucro Real (累積制)',
    rate: 0.073,
    formula: 'PIS = RB × 3.65% / COFINS = RB × 3.65% (無抵扣)',
    pis: 0.0365,
    cofins: 0.0365
  }
};

const PIS_IMPORT = 0.021;
const COFINS_IMPORT = 0.0965;
const CBS_RATE = 0.009;
const IBS_RATE = 0.001;
const GROSS_MARGIN = 0.30;
const CREDIT_RATIO = 0.50;

function formatMoney(value: number): string {
  return 'R$ ' + value.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function parseMoney(value: string): number {
  return parseFloat(value.replace(/[R$\s.,]/g, '').replace(/\./g, '').replace(/,/g, '.')) || 0;
}

function calculateImportTax(cif: number, ncmRate: number, ipiRate: number, icmsRate: number) {
  const ii = cif * (ncmRate / 100);
  const baseIpi = cif + ii;
  const ipi = baseIpi * (ipiRate / 100);
  const pis = cif * PIS_IMPORT;
  const cofins = cif * COFINS_IMPORT;
  const baseIcms = cif + ii + ipi + pis + cofins;
  const icms = baseIcms / (1 - icmsRate / 100) * (icmsRate / 100);
  
  return { ii, ipi, pis, cofins, icms, total: ii + ipi + pis + cofins + icms };
}

function updateCalculation() {
  const revenueInput = document.getElementById('annual-revenue') as HTMLInputElement;
  const cifInput = document.getElementById('cif-value') as HTMLInputElement;
  const reformCheckbox = document.getElementById('enable-reform') as HTMLInputElement;
  const resultsBody = document.getElementById('results-body');
  const importResults = document.getElementById('import-results');
  
  if (!revenueInput || !cifInput || !resultsBody) return;
  
  const revenue = parseMoney(revenueInput.value);
  const cif = parseMoney(cifInput.value);
  const useReform = reformCheckbox?.checked || false;
  
  const ncmRate = parseFloat((document.getElementById('ncm-rate') as HTMLInputElement)?.value) || 10;
  const ipiRate = parseFloat((document.getElementById('ipi-rate') as HTMLInputElement)?.value) || 10;
  const icmsRate = parseFloat((document.getElementById('icms-rate') as HTMLInputElement)?.value) || 18;
  
  const adicionalYes = (document.querySelector('input[name="adicional"]:checked') as HTMLInputElement)?.value === 'yes';
  const profit = revenue * GROSS_MARGIN;
  const adicionalAmount = adicionalYes && profit > 240000 ? (profit - 240000) * 0.10 : 0;
  
  const importTax = calculateImportTax(cif, ncmRate, ipiRate, icmsRate);
  
  if (document.getElementById('tax-ii')) {
    document.getElementById('tax-ii').textContent = formatMoney(importTax.ii);
    document.getElementById('tax-ipi').textContent = formatMoney(importTax.ipi);
    document.getElementById('tax-pis').textContent = formatMoney(importTax.pis);
    document.getElementById('tax-cofins').textContent = formatMoney(importTax.cofins);
    document.getElementById('tax-icms').textContent = formatMoney(importTax.icms);
    document.getElementById('tax-total').textContent = formatMoney(importTax.total);
  }
  
  let html = '';
  
  Object.entries(REGIME_DATA).forEach(([key, data]) => {
    let total = 0;
    let formula = data.formula;
    
    if (key === 'simples') {
      total = revenue * data.rate;
      formula = `DAS = RB × 6%`;
    } else if (key.includes('presumido')) {
      total = revenue * (data.pis + data.cofins) + profit * 0.25 + adicionalAmount;
      if (useReform) {
        total -= revenue * 0.01;
      }
    } else if (key.includes('real-nao-cumulativo')) {
      const irpjCsll = profit * 0.25 + adicionalAmount;
      const creditablePis = revenue * data.pis * CREDIT_RATIO;
      const creditableCofins = revenue * data.cofins * CREDIT_RATIO;
      total = revenue * (data.pis + data.cofins) + irpjCsll - creditablePis - creditableCofins;
      if (useReform) {
        total -= revenue * 0.01;
      }
    } else if (key.includes('real-cumulativo')) {
      total = revenue * (data.pis + data.cofins) + profit * 0.25 + adicionalAmount;
      if (useReform) {
        total -= revenue * 0.01;
      }
    }
    
    html += `
      <tr>
        <td>${data.name}</td>
        <td>${formula}</td>
        <td>${formatMoney(total)}</td>
      </tr>
    `;
  });
  
  if (useReform) {
    const cbs = revenue * CBS_RATE;
    const ibs = revenue * IBS_RATE;
    html += `
      <tr style="background: rgba(125, 211, 252, 0.1);">
        <td>CBS + IBS (2026稅改)</td>
        <td>CBS = RB × 0.9% / IBS = RB × 0.1%</td>
        <td>${formatMoney(cbs + ibs)}</td>
      </tr>
    `;
  }
  
  resultsBody.innerHTML = html;
}

document.addEventListener('DOMContentLoaded', () => {
  const revenueInput = document.getElementById('annual-revenue');
  const cifInput = document.getElementById('cif-value');
  const reformCheckbox = document.getElementById('enable-reform');
  const ncmInput = document.getElementById('ncm-rate');
  const ipiInput = document.getElementById('ipi-rate');
  const icmsInput = document.getElementById('icms-rate');
  const adicionalInputs = document.querySelectorAll('input[name="adicional"]');
  const regimeInputs = document.querySelectorAll('input[name="tax-regime"]');
  
  [revenueInput, cifInput, ncmInput, ipiInput, icmsInput].forEach(input => {
    input?.addEventListener('input', updateCalculation);
  });
  
  adicionalInputs.forEach(input => {
    input?.addEventListener('change', updateCalculation);
  });
  
  reformCheckbox?.addEventListener('change', updateCalculation);
  
  updateCalculation();
});
</script>
---
interface Props {
  fullMode?: {
    import: string;
    importTax: string;
    sales: string;
    salesTax: string;
    net: string;
  };
  subfMode?: {
    import: string;
    importTax: string;
    sales: string;
    salesTax: string;
    net: string;
  };
}

const {
  fullMode = {
    import: '$1,000',
    importTax: '-$420',
    sales: '$2,400',
    salesTax: '+$672',
    net: '$252'
  },
  subfMode = {
    import: '$500',
    importTax: '-$210',
    sales: '$2,137.50',
    salesTax: '+$598.50',
    net: '$389'
  }
} = Astro.props;
---

<div class="tax-factory" id="tax-factory">
  <div class="factory-pipeline">
    <div class="factory-station import-station">
      <div class="station-icon">📦</div>
      <div class="station-name">關口1 - 進口</div>
      <div class="station-value" data-value="import">{fullMode.import}</div>
      <div class="station-formula">申報金額</div>
      <div class="station-tax">
        <span class="tax-badge">-28%</span>
        <div class="tax-value" data-tax="import">{fullMode.importTax}</div>
      </div>
    </div>
    
    <div class="conveyor-belt">
      <div class="belt-segment"></div>
      <div class="belt-arrow">▶</div>
    </div>
    
    <div class="factory-station sales-station">
      <div class="station-icon">🏭</div>
      <div class="station-name">關口2 - 銷售</div>
      <div class="station-value" data-value="sales">{fullMode.sales}</div>
      <div class="station-formula">銷售發票</div>
      <div class="station-tax">
        <span class="tax-badge">+28%</span>
        <div class="tax-value" data-tax="sales">{fullMode.salesTax}</div>
      </div>
    </div>
    
    <div class="conveyor-belt">
      <div class="belt-segment"></div>
      <div class="belt-arrow">▶</div>
    </div>
    
    <div class="factory-station net-station">
      <div class="station-icon">💰</div>
      <div class="station-name">結算中心</div>
      <div class="station-value net-value" data-value="net">{fullMode.net}</div>
      <div class="station-formula">實繳稅額</div>
      <div class="station-result">
        <span class="result-badge">淨額</span>
      </div>
    </div>
  </div>
  
  <div class="factory-controls">
    <div class="tax-regime-selector">
      <label for="tax-regime">稅制選擇:</label>
      <select id="tax-regime" class="tax-select">
        <option value="simples">Simples Nacional (單一稅)</option>
        <option value="presumido-cumulativo">Lucro Presumido (累積制)</option>
        <option value="presumido-nao-cumulativo">Lucro Presumido (非累積制)</option>
        <option value="real-cumulativo">Lucro Real (累積制-特定行業)</option>
        <option value="real-nao-cumulativo">Lucro Real (非累積制-一般行業)</option>
      </select>
      <div class="rate-display">
        <span class="rate-badge">PIS: <span id="pis-rate">0%</span></span>
        <span class="rate-badge">COFINS: <span id="cofins-rate">0%</span></span>
      </div>
    </div>
    <div class="threshold-check">
      <label for="annual-revenue">年度營業額 (R$/年):</label>
      <input type="text" id="annual-revenue" class="revenue-input" placeholder="例如: 5000000" value="5000000" />
      <div class="threshold-warning" id="threshold-warning"></div>
    </div>
  </div>
  
  <div class="factory-dashboard" id="factory-dashboard">
    <div class="dashboard-card full-mode">
      <div class="card-header">全報模式</div>
      <div class="card-value">{fullMode.net}</div>
      <div class="card-label">實繳稅額</div>
      <div class="card-status">✅ 合規</div>
    </div>
    <div class="dashboard-card subf-mode">
      <div class="card-header">低報模式</div>
      <div class="card-value">{subfMode.net}</div>
      <div class="card-label">實繳稅額</div>
      <div class="card-status">⚠️ 高稅</div>
    </div>
  </div>
  
  <div class="import-tax-panel" id="import-tax-panel">
    <h4>🛃 進口稅計算 (Tributos na Importação)</h4>
    <div class="import-inputs">
      <div class="input-group">
        <label>CIF (Valor Aduaneiro):</label>
        <input type="number" id="cif-value" value="1000" />
      </div>
      <div class="input-group">
        <label>NCM 稅率 (%):</label>
        <input type="number" id="ncm-rate" value="10" />
      </div>
      <div class="input-group">
        <label>IPI 稅率 (%):</label>
        <input type="number" id="ipi-rate" value="10" />
      </div>
      <div class="input-group">
        <label>ICMS 稅率 (%):</label>
        <input type="number" id="icms-rate" value="18" />
      </div>
    </div>
    <div class="import-results">
<div class="tax-line">II (關稅): <span id="tax-ii">100.00</span></div>
    <div class="tax-line">IPI: <span id="tax-ipi">110.00</span></div>
    <div class="tax-line">PIS Importação: <span id="tax-pis">21.00</span></div>
    <div class="tax-line">COFINS Importação: <span id="tax-cofins">96.50</span></div>
    <div class="tax-line">ICMS: <span id="tax-icms">291.40</span></div>
    <div class="tax-line total">進口稅合計: <span id="tax-total">618.90</span></div>
    </div>
  </div>

  <div class="adicional-panel" id="adicional-panel">
    <h4>📊 Adicional IRPJ 計算</h4>
    <div class="profit-input-group">
      <label for="annual-profit">年度利潤 (Lucro/年):</label>
      <input type="number" id="annual-profit" class="profit-input" placeholder="例如: 300000" />
    </div>
    <div class="adicional-result">
      <span class="adicional-label">Adicional IRPJ (10%):</span>
      <span class="adicional-value" id="adicional-value">R$ 0.00</span>
    </div>
    <div class="adicional-note">* 年化利潤超過 R$240,000 時加徵 10%</div>
  </div>

  <div class="tax-reform-notice">
    <h4>📅 2026 稅改過渡期提醒</h4>
    <p>自 2026 年 1 月 1 日起，PIS/COFINS 將逐步被 CBS (0.9%) + IBS (0.1%) 取代</p>
    <label class="reform-toggle">
      <input type="checkbox" id="enable-2026-reform" />
      啟用 2026 稅改模擬 (Reforma Tributária)
    </label>
    <div class="cbs-ibs-result" id="cbs-ibs-result" style="display: none;">
      <div class="tax-line">CBS (0.9%): <span id="cbs-value">0</span></div>
      <div class="tax-line">IBS (0.1%): <span id="ibs-value">0</span></div>
      <div class="tax-line total">CBS+IBS 合計: <span id="cbs-ibs-total">0</span></div>
    </div>
  </div>
</div>

<script define:vars={{ fullMode, subfMode }}>
const PIS_RATES = {
  'simples': 0,
  'presumido-cumulativo': 0.0065,
  'presumido-nao-cumulativo': 0.0165,
  'real-cumulativo': 0.0365,
  'real-nao-cumulativo': 0.0165
};

const COFINS_RATES = {
  'simples': 0,
  'presumido-cumulativo': 0.03,
  'presumido-nao-cumulativo': 0.076,
  'real-cumulativo': 0.0365,
  'real-nao-cumulativo': 0.076
};

function updateRateDisplay(regime) {
  const pisRate = (PIS_RATES[regime] * 100).toFixed(2);
  const cofinsRate = (COFINS_RATES[regime] * 100).toFixed(2);
  const pisEl = document.getElementById('pis-rate');
  const cofinsEl = document.getElementById('cofins-rate');
  if (pisEl) pisEl.textContent = pisRate + '%';
  if (cofinsEl) cofinsEl.textContent = cofinsRate + '%';
}

function checkThreshold(revenue) {
  if (revenue > 4800000) {
    return { regime: 'simples', warning: '⚠️ 超過 R$4.8M/年，Simples必須退出，強制使用 Lucro Presumido 或 Lucro Real' };
  }
  if (revenue > 78000000) {
    return { regime: 'presumido', warning: '⚠️ 超過 R$78M/年，必須使用 Lucro Real' };
  }
  return { regime: '', warning: '' };
}

function calculateImportTax(cif, ncmRate, ipiRate, icmsRate) {
  const ii = cif * (ncmRate / 100);
  const baseIpi = cif + ii;
  const ipi = baseIpi * (ipiRate / 100);
  const pis = cif * 0.021;
  const cofins = cif * 0.0965;
  const baseIcms = cif + ii + ipi + pis + cofins;
  const icms = baseIcms / (1 - icmsRate / 100) * (icmsRate / 100);
  
  return { ii, ipi, pis, cofins, icms, total: ii + ipi + pis + cofins + icms };
}

function calculateAdicional(profit) {
  if (profit > 240000) {
    return profit * 0.10;
  }
  return 0;
}

function updateAdicional() {
  const profit = parseFloat(document.getElementById('annual-profit')?.value) || 0;
  const adicional = calculateAdicional(profit);
  const adicionalEl = document.getElementById('adicional-value');
  if (adicionalEl) {
    adicionalEl.textContent = 'R$ ' + adicional.toFixed(2);
  }
}

const CBS_RATE = 0.009;
const IBS_RATE = 0.001;

function calculateCBS_IBS(revenue) {
  return {
    cbs: revenue * CBS_RATE,
    ibs: revenue * IBS_RATE,
    total: revenue * (CBS_RATE + IBS_RATE)
  };
}

function toggleReformSimulation() {
  const checkbox = document.getElementById('enable-2026-reform');
  const resultDiv = document.getElementById('cbs-ibs-result');
  const revenueInput = document.getElementById('annual-revenue');
  if (checkbox && resultDiv) {
    if (checkbox.checked) {
      resultDiv.style.display = 'block';
      let revenue = 0;
      if (revenueInput && revenueInput.value) {
        revenue = parseFloat(revenueInput.value.replace(/,/g, '').replace(/R\$\s*/g, '')) || 0;
      }
      if (revenue === 0) {
        resultDiv.innerHTML = '<p style="color:#E5FF00;font-size:0.85rem;">⚠️ 請先在上方輸入年度營業額</p>';
        return;
      }
      const result = calculateCBS_IBS(revenue);
      document.getElementById('cbs-value').textContent = 'R$ ' + result.cbs.toFixed(2);
      document.getElementById('ibs-value').textContent = 'R$ ' + result.ibs.toFixed(2);
      document.getElementById('cbs-ibs-total').textContent = 'R$ ' + result.total.toFixed(2);
    } else {
      resultDiv.style.display = 'none';
      resultDiv.innerHTML = '';
    }
  }
}

function updateImportTax() {
  const cif = parseFloat(document.getElementById('cif-value')?.value) || 0;
  const ncmRate = parseFloat(document.getElementById('ncm-rate')?.value) || 0;
  const ipiRate = parseFloat(document.getElementById('ipi-rate')?.value) || 0;
  const icmsRate = parseFloat(document.getElementById('icms-rate')?.value) || 0;
  
  const result = calculateImportTax(cif, ncmRate, ipiRate, icmsRate);
  
  document.getElementById('tax-ii').textContent = result.ii.toFixed(2);
  document.getElementById('tax-ipi').textContent = result.ipi.toFixed(2);
  document.getElementById('tax-pis').textContent = result.pis.toFixed(2);
  document.getElementById('tax-cofins').textContent = result.cofins.toFixed(2);
  document.getElementById('tax-icms').textContent = result.icms.toFixed(2);
  document.getElementById('tax-total').textContent = result.total.toFixed(2);
}

document.addEventListener('DOMContentLoaded', () => {
  const factoryBtns = document.querySelectorAll('[data-action="switch-factory"]');
  const importStation = document.querySelector('[data-value="import"]');
  const importTax = document.querySelector('[data-tax="import"]');
  const salesStation = document.querySelector('[data-value="sales"]');
  const salesTax = document.querySelector('[data-tax="sales"]');
  const netStation = document.querySelector('[data-value="net"]');
  
  const modeData = {
    full: fullMode,
    subf: subfMode
  };
  
  factoryBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const mode = btn.getAttribute('data-mode');
      factoryBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      
      const data = modeData[mode];
      if (data && importStation && importTax && salesStation && salesTax && netStation) {
        importStation.textContent = data.import;
        importTax.textContent = data.importTax;
        salesStation.textContent = data.sales;
        salesTax.textContent = data.salesTax;
        netStation.textContent = data.net;
        
        [importStation, salesStation, netStation].forEach(el => {
          el.closest('.factory-station')?.classList.add('animate-update');
          setTimeout(() => el.closest('.factory-station')?.classList.remove('animate-update'), 400);
        });
      }
    });
  });

  const revenueInput = document.getElementById('annual-revenue');
  const thresholdWarning = document.getElementById('threshold-warning');
  const taxRegimeSelect = document.getElementById('tax-regime');
  
  if (taxRegimeSelect) {
    taxRegimeSelect.addEventListener('change', (e) => {
      updateRateDisplay(e.target.value);
    });
    updateRateDisplay(taxRegimeSelect.value);
  }
  
  if (revenueInput && thresholdWarning && taxRegimeSelect) {
    revenueInput.addEventListener('input', (e) => {
      const revenue = parseFloat(e.target.value.replace(/,/g, '')) || 0;
      const result = checkThreshold(revenue);
      
      if (result.warning) {
        thresholdWarning.textContent = result.warning;
        thresholdWarning.style.display = 'block';
      } else {
        thresholdWarning.textContent = '';
        thresholdWarning.style.display = 'none';
      }
    });
  }
  
  const cifInput = document.getElementById('cif-value');
  const ncmInput = document.getElementById('ncm-rate');
  const ipiInput = document.getElementById('ipi-rate');
  const icmsInput = document.getElementById('icms-rate');
  
  if (cifInput && ncmInput && ipiInput && icmsInput) {
    updateImportTax();
    cifInput.addEventListener('input', updateImportTax);
    ncmInput.addEventListener('input', updateImportTax);
    ipiInput.addEventListener('input', updateImportTax);
    icmsInput.addEventListener('input', updateImportTax);
  }
  
  const profitInput = document.getElementById('annual-profit');
  if (profitInput) {
    profitInput.addEventListener('input', updateAdicional);
  }

  const reformCheckbox = document.getElementById('enable-2026-reform');
  if (reformCheckbox) {
    reformCheckbox.addEventListener('change', toggleReformSimulation);
  }
});
</script>

<style>
.tax-factory {
  background: linear-gradient(135deg, rgba(212,168,67,0.08) 0%, rgba(0,255,135,0.05) 100%);
  border: 1px solid var(--color-border, #333);
  border-radius: 16px;
  padding: 1.5rem;
  margin: 1.5rem 0;
}

.factory-pipeline {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  margin-bottom: 1.5rem;
}

.factory-station {
  flex: 1;
  background: #1a1a24;
  border: 1px solid #333;
  border-radius: 12px;
  padding: 1rem;
  text-align: center;
  transition: all 0.3s ease;
  position: relative;
}

.factory-station::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: #D4A843;
}

.import-station::before { background: #00FF87; }
.sales-station::before { background: #D4A843; }
.net-station::before { background: #7DD3FC; }

.factory-station:hover {
  transform: translateY(-4px);
  border-color: #D4A843;
  box-shadow: 0 0 20px rgba(212,168,67,0.2);
}

.station-icon {
  font-size: 1.5rem;
  margin-bottom: 0.5rem;
}

.station-name {
  font-size: 0.8rem;
  color: #888;
  margin-bottom: 0.5rem;
}

.station-value {
  font-size: 1.25rem;
  font-weight: 700;
  color: #f5f5f0;
  margin-bottom: 0.25rem;
}

.net-value {
  color: #00FF87;
  font-size: 1.5rem;
}

.station-formula {
  font-size: 0.7rem;
  color: #666;
  margin-bottom: 0.5rem;
}

.station-tax {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.25rem;
}

.tax-badge {
  font-size: 0.7rem;
  padding: 2px 8px;
  border-radius: 4px;
  font-weight: 600;
}

.import-station .tax-badge {
  background: rgba(0,255,135,0.15);
  color: #00FF87;
}

.sales-station .tax-badge {
  background: rgba(212,168,67,0.15);
  color: #D4A843;
}

.tax-value {
  font-size: 0.9rem;
  font-weight: 600;
}

.import-station .tax-value { color: #00FF87; }
.sales-station .tax-value { color: #E5FF00; }

.station-result {
  margin-top: 0.5rem;
}

.result-badge {
  background: rgba(125,211,252,0.15);
  color: #7DD3FC;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 0.75rem;
  font-weight: 600;
}

/* Conveyor Belt */
.conveyor-belt {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  padding: 0.25rem 0;
}

.belt-segment {
  width: 3px;
  height: 30px;
  background: repeating-linear-gradient(
    180deg,
    #D4A843 0px,
    #D4A843 6px,
    transparent 6px,
    transparent 12px
  );
  animation: conveyor-move-vertical 1s linear infinite;
}

.belt-arrow {
  color: #D4A843;
  animation: arrow-pulse 1s ease-in-out infinite;
}

@keyframes conveyor-move-vertical {
  0% { background-position: 0 0; }
  100% { background-position: 0 12px; }
}

@keyframes arrow-pulse {
  0%, 100% { transform: translateY(0); opacity: 1; }
  50% { transform: translateY(3px); opacity: 0.6; }
}

/* Factory Controls */
.factory-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  margin-bottom: 1.5rem;
  flex-wrap: wrap;
}

.tax-regime-selector {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 1rem;
}

.tax-regime-selector label {
  color: #888;
  font-size: 0.85rem;
}

.tax-select {
  background: #1a1a24;
  border: 1px solid #333;
  color: #f5f5f0;
  padding: 0.5rem 1rem;
  border-radius: 8px;
  font-size: 0.85rem;
  cursor: pointer;
}

.tax-select:focus {
  outline: none;
  border-color: #D4A843;
}

.rate-display {
  display: flex;
  gap: 1rem;
  margin-top: 0.5rem;
}

.rate-badge {
  font-size: 0.75rem;
  padding: 0.25rem 0.5rem;
  border-radius: 4px;
  background: rgba(212, 168, 67, 0.15);
  color: #D4A843;
}

.threshold-check {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  margin-bottom: 1rem;
}

.revenue-input {
  background: #1a1a24;
  border: 1px solid #333;
  color: #f5f5f0;
  padding: 0.5rem 1rem;
  border-radius: 8px;
  font-size: 0.85rem;
}

.revenue-input:focus {
  outline: none;
  border-color: #D4A843;
}

.threshold-warning {
  font-size: 0.75rem;
  color: #E5FF00;
  margin-top: 0.25rem;
  min-height: 1rem;
}

/* Factory Dashboard */
.factory-dashboard {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
}

.dashboard-card {
  background: #1a1a24;
  border: 1px solid #333;
  border-radius: 12px;
  padding: 1rem;
  text-align: center;
}

.dashboard-card .card-header {
  font-size: 0.75rem;
  color: #888;
  margin-bottom: 0.25rem;
}

.dashboard-card .card-value {
  font-size: 1.25rem;
  font-weight: 700;
  color: #00FF87;
  margin-bottom: 0.25rem;
}

.dashboard-card .card-label {
  font-size: 0.7rem;
  color: #666;
  margin-bottom: 0.25rem;
}

.dashboard-card .card-status {
  font-size: 0.75rem;
  font-weight: 500;
}

.dashboard-card:first-child .card-status { color: #00FF87; }
.dashboard-card:last-child .card-status { color: #E5FF00; }

/* Animation */
.animate-update {
  animation: value-pulse 0.4s ease;
}

@keyframes value-pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

/* Mobile */
@media (max-width: 768px) {
  .factory-dashboard {
    grid-template-columns: 1fr;
  }
}

/* Import Tax Panel */
.import-tax-panel {
  background: #1a1a24;
  border: 1px solid #333;
  border-radius: 12px;
  padding: 1rem;
  margin: 1rem 0;
}

.import-tax-panel h4 {
  color: #D4A843;
  margin: 0 0 1rem 0;
  font-size: 1rem;
}

.import-inputs {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0.5rem;
  margin-bottom: 1rem;
}

.input-group {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.input-group label {
  font-size: 0.75rem;
  color: #888;
}

.input-group input {
  background: #0a0a0f;
  border: 1px solid #333;
  color: #f5f5f0;
  padding: 0.5rem;
  border-radius: 4px;
  font-size: 0.85rem;
}

.tax-line {
  display: flex;
  justify-content: space-between;
  padding: 0.5rem 0;
  border-bottom: 1px solid #222;
  font-size: 0.85rem;
}

.tax-line.total {
  font-weight: 700;
  color: #D4A843;
  border-top: 1px solid #D4A843;
  margin-top: 0.5rem;
  padding-top: 0.5rem;
}

/* Adicional IRPJ Panel */
.adicional-panel {
  background: #1a1a24;
  border: 1px solid #333;
  border-radius: 12px;
  padding: 1rem;
  margin: 1rem 0;
}

.adicional-panel h4 {
  color: #00FF87;
  margin: 0 0 1rem 0;
  font-size: 1rem;
}

.profit-input-group {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  margin-bottom: 1rem;
}

.profit-input-group label {
  font-size: 0.85rem;
  color: #888;
}


      <p class="footer-copy">© 2026 BrazilTax. 為跨境電商提供最完善的巴西落地解決方案。</p>
    </footer>

    <!-- ── Exit Intent Popup ───────────────────────────────── -->
    <div class="exit-popup" id="exit-popup" style="display:none;">

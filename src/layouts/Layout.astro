---
import '../styles/global.css';
import '@fontsource-variable/inter';

export interface Props {
  title?: string;
  description?: string;
}

const { title = '巴西出海實戰手冊', description = '跨境電商出海、落地巴西的完整實戰指南' } = Astro.props;
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | 專業會計服務</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <!-- Navbar -->
    <nav class="glass-nav fixed top-0 left-0 right-0 z-50">
      <div class="nav-container">
        <a href="/" class="brand">
          黃金雨林 <span style="font-weight:400;font-size:0.8em;opacity:0.7;">GOLDEN RAINFOREST</span>
        </a>

        <div class="nav-links">
          <a href="/" class="nav-link">🏠 首頁</a>
          <a href="/handbook" class="nav-link">📖 實戰手冊</a>
          <a href="/handbook#phase-insights" class="nav-link">📊 市場洞察</a>
          <a href="/media" class="nav-link">🎬 媒體中心</a>
          <a href="/tools" class="nav-link">🧮 免費工具</a>
          <a href="https://braziltax.netlify.app/#contact" class="nav-link">聯繫我們</a>
        </div>

        <div class="nav-actions">
          <a href="https://braziltax.netlify.app/tax-calculator" class="nav-link" style="border:1px solid var(--color-border);border-radius:0.5rem;padding:0.4rem 0.8rem;">
            🇧🇷 稅務計算器
          </a>
          <a href="https://braziltax.netlify.app/#contact" class="btn-gold-primary" style="font-size:0.85rem;padding:0.45rem 1rem;">
            免費咨詢
          </a>
        </div>
      </div>
    </nav>

    <!-- Global Search Bar (sticky below navbar) -->
    <div class="global-search-bar" id="global-search-bar">
      <div class="global-search-container">
        <span class="global-search-icon">🔍</span>
        <input
          type="text"
          id="global-search-input"
          class="global-search-input"
          placeholder="搜尋手冊內容（如：RADAR、Lucro Real、CNPJ...）"
          autocomplete="off"
        />
        <button class="global-search-close" id="global-search-close" style="display:none;">✕</button>
      </div>
      <div id="global-search-results" class="global-search-results" style="display:none;"></div>
    </div>

    <!-- Page Content -->
    <main class="main-content">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="site-footer">
      <div class="footer-brand">專業會計服務</div>
      <p class="footer-copy">© 2026 BrazilTax. 為跨境電商提供最完善的巴西落地解決方案。</p>
    </footer>
  </body>
</html>

<script>
// ── Navbar Scroll Shrink ──────────────────────────────────
(function initNavbarScroll() {
  const nav = document.querySelector('.glass-nav');
  const searchBar = document.getElementById('global-search-bar');
  if (!nav) return;

  let ticking = false;
  const onScroll = () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        if (window.scrollY > 50) {
          nav.classList.add('scrolled');
          if (searchBar) searchBar.classList.add('scrolled');
        } else {
          nav.classList.remove('scrolled');
          if (searchBar) searchBar.classList.remove('scrolled');
        }
        ticking = false;
      });
      ticking = true;
    }
  };

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
})();

// ── Magnetic Button Effect ─────────────────────────────────
(function initMagneticButtons() {
  const buttons = document.querySelectorAll('.magnetic-btn');
  buttons.forEach(btn => {
    btn.addEventListener('mousemove', (e) => {
      const rect = btn.getBoundingClientRect();
      const x = e.clientX - rect.left - rect.width / 2;
      const y = e.clientY - rect.top - rect.height / 2;
      btn.style.transform = `translate(${x * 0.3}px, ${y * 0.3}px)`;
      const angle = Math.atan2(y, x) * (180 / Math.PI) + 180;
      btn.style.setProperty('--btn-angle', `${angle}deg`);
    });
    btn.addEventListener('mouseleave', () => {
      btn.style.transform = 'translate(0, 0)';
    });
  });
})();

// ── Scroll-driven Page Animations ──────────────────────────
(function initScrollAnimations() {
  const animElements = document.querySelectorAll('.animate-on-scroll');
  if (animElements.length === 0) return;

  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        const delay = e.target.classList.contains('delay-100') ? 100 :
                     e.target.classList.contains('delay-200') ? 200 :
                     e.target.classList.contains('delay-300') ? 300 :
                     e.target.classList.contains('delay-400') ? 400 :
                     e.target.classList.contains('delay-500') ? 500 : 0;
        setTimeout(() => {
          e.target.classList.add('in-view');
        }, delay);
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

  animElements.forEach(el => obs.observe(el));
})();

// ── Global Search Bar ─────────────────────────────────────
(function initGlobalSearch() {
  const bar = document.getElementById('global-search-bar');
  const input = document.getElementById('global-search-input');
  const closeBtn = document.getElementById('global-search-close');
  const resultsEl = document.getElementById('global-search-results');
  if (!bar || !input || !resultsEl) return;

  let fuse: any = null;
  let searchIndex: any[] = [];
  let searchTimeout: any;
  let indexLoaded = false;
  let pollTimer: any;

  function initFuse(data: any[]) {
    if (data.length === 0 || indexLoaded) return;
    searchIndex = data;
    indexLoaded = true;
    if (pollTimer) clearInterval(pollTimer);
    import('https://cdn.jsdelivr.net/npm/fuse.js@7.0.0/dist/fuse.min.js').then(mod => {
      const Fuse = mod.default || (mod as any).Fuse;
      fuse = new Fuse(searchIndex, {
        keys: [
          { name: 'title', weight: 0.5 },
          { name: 'description', weight: 0.3 },
          { name: 'tags', weight: 0.15 },
          { name: 'content', weight: 0.1 },
          { name: 'phaseLabel', weight: 0.05 },
        ],
        threshold: 0.35,
        ignoreLocation: true,
        includeScore: true,
        includeMatches: true,
      });
    }).catch(() => { fuse = null; });
  }

  // Strategy 1: Try window.searchData (injected by handbook page)
  if ((window as any).searchData && (window as any).searchData.length > 0) {
    initFuse((window as any).searchData);
  }

  // Strategy 2: Poll for window.searchData (in case handbook script runs later)
  pollTimer = setInterval(() => {
    if ((window as any).searchData && (window as any).searchData.length > 0) {
      initFuse((window as any).searchData);
    }
  }, 200);

  // Strategy 3: Fetch static JSON index (works on all pages + after build)
  fetch('/search-index.json')
    .then(r => {
      if (r.ok) return r.json();
      throw new Error('not found');
    })
    .then(data => {
      if (data && data.length > 0) {
        initFuse(data);
      }
    })
    .catch(() => {});

  // Stop polling after 5 seconds
  setTimeout(() => { if (pollTimer) clearInterval(pollTimer); }, 5000);

  const highlight = (text: string, term: string) => {
    if (!term || !text) return text;
    try {
      const escapedTerm = term.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      const regex = new RegExp(`(${escapedTerm})`, 'gi');
      return String(text).replace(regex, '<mark style="background:rgba(229,255,0,0.15);color:var(--color-neon-yellow);border-radius:0.2rem;padding:0 0.1rem;">$1</mark>');
    } catch { return text; }
  };

  input.addEventListener('input', () => {
    clearTimeout(searchTimeout);
    const q = input.value.trim();
    if (closeBtn) closeBtn.style.display = q ? 'flex' : 'none';
    searchTimeout = setTimeout(() => {
      if (!q) { resultsEl.style.display = 'none'; return; }
      if (!indexLoaded || searchIndex.length === 0) {
        resultsEl.style.display = 'block';
        resultsEl.innerHTML = '<div style="color:var(--color-muted);font-size:0.85rem;text-align:center;padding:1rem;">載入索引中...</div>';
        return;
      }

      let results: any[] = [];
      if (fuse) {
        results = fuse.search(q).map((r: any) => ({
          slug: r.item.slug, title: r.item.title, description: r.item.description,
          icon: r.item.icon, phase: r.item.phase, score: r.score,
        }));
      } else {
        const lowerQ = q.toLowerCase();
        results = searchIndex.filter(item =>
          item.title.toLowerCase().includes(lowerQ) ||
          item.description.toLowerCase().includes(lowerQ) ||
          (item.tags || []).some((t: string) => t.toLowerCase().includes(lowerQ))
        ).map(item => ({
          slug: item.slug, title: item.title, description: item.description,
          icon: item.icon, phase: item.phase, score: 0,
        }));
      }

      resultsEl.style.display = 'block';
      if (results.length === 0) {
        resultsEl.innerHTML = `<div style="color:var(--color-muted);font-size:0.85rem;text-align:center;padding:1rem;">未找到相關內容</div>`;
      } else {
        resultsEl.innerHTML = results.slice(0, 8).map((r: any) => `
          <a href="/handbook/${r.slug}" style="display:flex;align-items:center;gap:10px;padding:10px 14px;border-radius:0.5rem;color:var(--color-text);font-size:0.85rem;text-decoration:none;transition:all 0.2s;">
            <span style="font-size:1.2rem;flex-shrink:0;">${r.icon || '📄'}</span>
            <div style="min-width:0;flex:1;">
              <div style="font-weight:600;color:var(--color-gold);margin-bottom:2px;">${highlight(r.title, q)}</div>
              <div style="font-size:0.75rem;color:var(--color-muted);line-height:1.3;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${highlight(r.description, q)}</div>
            </div>
          </a>
        `).join('');
      }
    }, 200);
  });

  // Close button
  closeBtn?.addEventListener('click', () => {
    input.value = '';
    resultsEl.style.display = 'none';
    closeBtn.style.display = 'none';
    input.blur();
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && document.activeElement === input) {
      input.value = '';
      resultsEl.style.display = 'none';
      closeBtn.style.display = 'none';
      input.blur();
    }
  });

  // Close results on outside click
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!bar.contains(target)) {
      resultsEl.style.display = 'none';
    }
  });
})();

// Mermaid Diagram Rendering
async function initMermaid() {
  if (typeof window === 'undefined') return;
  
  const mermaidModule = await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs');
  mermaidModule.default.initialize({
    startOnLoad: false,
    theme: 'base',
    themeVariables: {
      primaryColor: '#D4A843',
      primaryTextColor: '#f5f5f5',
      primaryBorderColor: '#D4A843',
      lineColor: '#D4A843',
      secondaryColor: '#0f0f18',
      tertiaryColor: '#1a1a2e',
      fontFamily: 'Inter, Noto Sans TC, sans-serif',
      fontSize: '14px',
      textColor: '#e5e5e5',
      nodeTextColor: '#e5e5e5',
    },
    flowchart: {
      curve: 'basis',
      padding: 15,
      nodeSpacing: 50,
      rankSpacing: 60,
    },
    sequence: {
      actorMargin: 40,
      boxMargin: 10,
    },
  });
  
  // Find all mermaid code blocks (Astro renders as pre.astro-code with data-language="mermaid")
  const codeBlocks = document.querySelectorAll('pre.astro-code[data-language="mermaid"]');
  
  for (const pre of codeBlocks) {
    if (pre.classList.contains('mermaid-rendered')) continue;
    pre.classList.add('mermaid-rendered');
    
    const code = pre.querySelector('code');
    if (!code) continue;
    
    const graphDefinition = code.textContent || '';
    if (!graphDefinition.trim()) continue;
    
    const div = document.createElement('div');
    div.className = 'mermaid';
    div.textContent = graphDefinition;
    
    pre.parentNode?.insertBefore(div, pre);
  }
  
  try {
    await mermaidModule.default.run({ querySelector: '.mermaid' });
  } catch (e) {
    console.warn('Mermaid render error:', e);
  }
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initMermaid);
} else {
  initMermaid();
}

// ── Mouse Trail Particle Effect ──────────────────────────
(function initMouseTrail() {
  const canvas = document.createElement('canvas');
  canvas.id = 'mouse-trail-canvas';
  canvas.style.cssText = 'position:fixed;top:0;left:0;width:100vw;height:100vh;z-index:1;pointer-events:none;overflow:hidden;opacity:0.5';
  document.body.appendChild(canvas);

  const ctx = canvas.getContext('2d');
  if (!ctx) return;

  let width = window.innerWidth;
  let height = window.innerHeight;
  canvas.width = width;
  canvas.height = height;

  window.addEventListener('resize', function() {
    width = window.innerWidth;
    height = window.innerHeight;
    canvas.width = width;
    canvas.height = height;
  });

  const particles: Array<{x:number;y:number;vx:number;vy:number;size:number;color:string;life:number;decay:number;isRing?:boolean;ringRadius?:number}> = [];
  const clickEffects: Array<{x:number;y:number;vx:number;vy:number;size:number;color:string;life:number;decay:number;isRing?:boolean;ringRadius?:number}> = [];
  let mouseX = width / 2;
  let mouseY = height / 2;

  document.addEventListener('mousemove', function(e) {
    mouseX = e.clientX;
    mouseY = e.clientY;
    if (Math.random() > 0.4) {
      createTrailParticle(mouseX, mouseY);
    }
  });

  document.addEventListener('click', function(e) {
    createClickBurst(e.clientX, e.clientY);
  });

  function createTrailParticle(x: number, y: number) {
    if (particles.length >= 40) particles.shift();
    const colors = ['rgba(212,168,67,', 'rgba(229,255,0,', 'rgba(0,255,135,', 'rgba(125,211,252,', 'rgba(232,228,217,'];
    particles.push({
      x: x + (Math.random() - 0.5) * 15,
      y: y + (Math.random() - 0.5) * 15,
      vx: (Math.random() - 0.5) * 2,
      vy: (Math.random() - 0.5) * 2,
      size: Math.random() * 8 + 4,
      color: colors[Math.floor(Math.random() * colors.length)],
      life: 1,
      decay: 0.025 + Math.random() * 0.025
    });
  }

  function createClickBurst(x: number, y: number) {
    const colors = ['rgba(212,168,67,', 'rgba(229,255,0,', 'rgba(0,255,135,', 'rgba(125,211,252,'];
    for (let i = 0; i < 15; i++) {
      const angle = (Math.PI * 2 * i) / 15;
      const speed = 2 + Math.random() * 3;
      clickEffects.push({
        x: x,
        y: y,
        vx: Math.cos(angle) * speed,
        vy: Math.sin(angle) * speed,
        size: Math.random() * 5 + 2,
        color: colors[Math.floor(Math.random() * colors.length)],
        life: 1,
        decay: 0.035 + Math.random() * 0.02
      });
    }
    clickEffects.push({
      x: x,
      y: y,
      vx: 0,
      vy: 0,
      size: 3,
      color: 'rgba(212,168,67,',
      life: 1,
      decay: 0.05,
      isRing: true,
      ringRadius: 3
    });
  }

  function drawGlow(x: number, y: number, size: number, color: string, life: number) {
    const gradient = ctx.createRadialGradient(x, y, 0, x, y, size * 2);
    gradient.addColorStop(0, color + (life * 0.8) + ')');
    gradient.addColorStop(0.5, color + (life * 0.4) + ')');
    gradient.addColorStop(1, color + '0)');
    ctx.beginPath();
    ctx.arc(x, y, size * 2, 0, Math.PI * 2);
    ctx.fillStyle = gradient;
    ctx.fill();
  }

  function drawRing(x: number, y: number, radius: number, color: string, life: number) {
    ctx.beginPath();
    ctx.arc(x, y, radius, 0, Math.PI * 2);
    ctx.strokeStyle = color + (life * 0.6) + ')';
    ctx.lineWidth = 2;
    ctx.stroke();
  }

  function animate() {
    ctx.clearRect(0, 0, width, height);

    for (let i = particles.length - 1; i >= 0; i--) {
      const p = particles[i];
      p.x += p.vx;
      p.y += p.vy;
      p.life -= p.decay;
      p.size *= 0.96;
      if (p.life <= 0 || p.size < 0.5) {
        particles.splice(i, 1);
        continue;
      }
      drawGlow(p.x, p.y, p.size, p.color, p.life);
    }

    for (let i = clickEffects.length - 1; i >= 0; i--) {
      const e = clickEffects[i];
      if (e.isRing) {
        e.ringRadius! += 6;
        e.life -= e.decay;
        if (e.life <= 0) {
          clickEffects.splice(i, 1);
          continue;
        }
        drawRing(e.x, e.y, e.ringRadius!, e.color, e.life);
      } else {
        e.x += e.vx;
        e.y += e.vy;
        e.vx *= 0.95;
        e.vy *= 0.95;
        e.life -= e.decay;
        e.size *= 0.97;
        if (e.life <= 0 || e.size < 0.5) {
          clickEffects.splice(i, 1);
          continue;
        }
        drawGlow(e.x, e.y, e.size, e.color, e.life);
      }
    }

    drawGlow(mouseX, mouseY, 18, 'rgba(212,168,67,', 0.4);
    requestAnimationFrame(animate);
  }

  animate();
})();
</script>

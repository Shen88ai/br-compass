    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO: Canonical URL -->
    <link rel="canonical" href={fullCanonicalUrl} />
    
    <!-- SEO: Primary Meta -->
    <title>{title} | 專業會計服務</title>
    <meta name="description" content={description} />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | 專業會計服務`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={fullCanonicalUrl} />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:site_name" content="黃金雨林 Golden Rainforest" />
    <meta property="og:locale" content="zh_TW" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@braziltax" />
    <meta name="twitter:title" content={`${title} | 專業會計服務`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />
    
    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <!-- Navbar -->
    <nav class="glass-nav fixed top-0 left-0 right-0 z-50">
      <div class="nav-container">
        <a href="/" class="brand">
          黃金雨林 <span style="font-weight:400;font-size:0.8em;opacity:0.7;">GOLDEN RAINFOREST</span>
        </a>

        <div class="nav-links">
          <a href="/" class="nav-link">🏠 首頁</a>
          <a href="/handbook" class="nav-link">📖 實戰手冊</a>
          <a href="/handbook#phase-insights" class="nav-link">📊 市場洞察</a>
          <a href="/media" class="nav-link">🎬 媒體中心</a>
          <a href="/tools" class="nav-link">🧮 免費工具</a>
          <a href="https://braziltax.netlify.app/#contact" class="nav-link">聯繫我們</a>
        </div>

        <div class="nav-actions">
          <a href="https://braziltax.netlify.app/tax-calculator" class="nav-link" style="border:1px solid var(--color-border);border-radius:0.5rem;padding:0.4rem 0.8rem;">
            🇧🇷 稅務計算器

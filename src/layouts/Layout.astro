    <!-- ── WhatsApp/TG Floating Button ───────────────────── -->
    <a href="https://t.me/braziltax" class="floating-contact" id="floating-contact" target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
        <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm0 2.182c1.165 0 2.143.378 2.935 1.134l-.002.002c.778.777 1.425 1.622 1.906 2.546.481.924.727 1.963.727 3.118s-.246 2.194-.727 3.118c-.481.924-1.128 1.77-1.906 2.546l-.002-.002c-.792.756-1.77 1.134-2.935 1.134a4.55 4.55 0 01-3.182-1.317c-.924-.924-1.317-2.053-1.317-3.438s.393-2.514 1.317-3.438c.924-.924 2.053-1.317 3.438-1.317h.15zm2.975 5.143c-.378-.378-.918-.605-1.622-.605-.703 0-1.317.227-1.841.681-.378.327-.697.838-.918 1.532-.15.462-.27.882-.378 1.261-.107.378-.35.836-.803 1.261l-.378.378c-.227.227-.474.303-.682.227-.208-.075-.436-.378-.603-.878-.15-.462-.327-.925-.481-1.388-.156-.378-.434-.832-.878-1.072-.444-.24-1.082-.24-1.476-.378-.15-.075-.303-.227-.378-.378-.075-.15-.15-.303-.15-.462s.075-.378.227-.546l.377-.378c.15-.15.303-.227.462-.227h.378l.462-.075c.378-.15.682-.15 1.06.075.378.227.682.681.925 1.164.243.482.378 1.013.378 1.592s-.135 1.11-.378 1.592c-.243.482-.547.936-.925 1.164-.378.227-.682.227-1.06.075l-.462-.075-.378-.075c-.15 0-.312.077-.462.227l-.377.378c-.152.15-.227.397-.227.546 0 .16.075.313.15.463.075.15.227.303.378.378.393.139.832.139 1.476.379.444.24.723.694.878 1.072.155.378.332.925.482 1.388a4.55 4.55 0 010 2.755c-.15.462-.378.925-.482 1.388-.155.378-.434.832-.878 1.072-.644.24-1.082.24-1.476.378-.15.075-.227.227-.378.378l-.378.378c-.152.152-.303.227-.462.227-.159 0-.312-.075-.462-.227l-.378-.378c-.15-.15-.303-.227-.461-.227h-.38l-.462.075c-.378.15-.682.15-1.06-.075a2.818 2.818 0 01-.925-1.164c-.243-.482-.378-1.013-.378-1.592s.135-1.11.378-1.592c.243-.482.547-.936.925-1.164.378-.227.682-.227 1.06-.075l.462.075.378.075c.15 0 .312-.077.462-.227l.377-.378c.15-.15.227-.312.227-.546z"/>
      </svg>
      <span class="floating-label">客服</span>

{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "br-compass",
  "compatibility_date": "2026-04-15",
  "main": "dist/server/entry.mjs",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "dist/client"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "br-compass-db",
      "database_id": "REPLACE_WITH_YOUR_ID"
    }
  ]
}
